# Node Environment
NODE_ENV=development

# Server Port
PORT=3000

# Session Secret (generate a strong random string)
SESSION_SECRET=your-super-secret-session-key-change-this

# PostgreSQL Database Configuration (Choose ONE option)

# Option 1: Using DATABASE_URL (Recommended for production - Digital Ocean, Railway, Heroku, etc.)
DATABASE_URL=postgresql://username:password@host:port/database_name

# Option 2: Using separate environment variables (Recommended for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fushidhalanka
DB_USER=postgres
DB_PASSWORD=postgres

# Admin User (created automatically on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure-password-change-this

# File Upload Settings
MAX_FILE_SIZE=10485760

# Firebase Configuration (if needed)
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-auth-domain
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-storage-bucket
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Email Configuration (if needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
