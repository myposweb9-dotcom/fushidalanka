<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Mobile Menu Toggle Button -->
  <button id="adminMenuToggle" type="button" aria-label="Toggle navigation">
    <i class="fas fa-bars"></i>
  </button>

  <div class="d-flex">
    <!-- Sidebar -->
    <div class="admin-sidebar">
      <h4><i class="fas fa-cog"></i> Admin Panel</h4>
      <nav class="nav flex-column">
        <a href="/admin/dashboard" class="nav-link">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a href="/admin/products" class="nav-link">
          <i class="fas fa-box"></i> Products
        </a>
        <a href="/admin/categories" class="nav-link">
          <i class="fas fa-tags"></i> Categories
        </a>
        <a href="/admin/users" class="nav-link">
          <i class="fas fa-users"></i> Users
        </a>
        <a href="/admin/testimonials" class="nav-link">
          <i class="fas fa-star"></i> Testimonials
        </a>
        <a href="/admin/content" class="nav-link">
          <i class="fas fa-edit"></i> Content
        </a>
        <a href="/admin/our-partners" class="nav-link">
          <i class="fas fa-handshake"></i> Our Partners
        </a>
        <a href="/admin/awards-recognition" class="nav-link active">
          <i class="fas fa-trophy"></i> Awards & Recognition
        </a>
        <a href="/admin/logout" class="nav-link">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-grow-1">
      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2><%= title %></h2>
            <p class="mb-0">Manage Awards & Recognition content</p>
          </div>
          <div class="d-flex align-items-center">
            <a href="/admin/dashboard" class="admin-btn admin-btn-secondary">
              <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
          </div>
        </div>
      </div>

      <div class="admin-content">
        <!-- Awards Content Stats -->
        <div class="row mb-4">
          <div class="col-md-4">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-trophy fa-2x text-primary mb-2"></i>
                <h4><%= (awardsContent || []).length %></h4>
                <p class="text-muted mb-0">Total Awards</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-star fa-2x text-warning mb-2"></i>
                <h4><%= (awardsContent || []).filter(a => a.featured).length %></h4>
                <p class="text-muted mb-0">Featured Awards</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-plus-circle fa-2x text-success mb-2"></i>
                <h4><%= (awardsContent || []).length %></h4>
                <p class="text-muted mb-0">Active Awards</p>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-8">
            <!-- Search and Filter -->
            <div class="admin-search mb-4">
              <input type="text" placeholder="Search awards..." id="awardsSearch">
              <i class="fas fa-search"></i>
            </div>

            <!-- Existing Awards Content -->
            <div class="admin-card">
              <div class="admin-card-header">
                <h5><i class="fas fa-list me-2"></i>All Awards & Recognition</h5>
              </div>
              <div class="admin-card-body">
                <div class="table-responsive">
                  <table class="admin-table">
                    <thead>
                      <tr>
                        <th>Award Title</th>
                        <th>Organization</th>
                        <th>Year</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="awardsTableBody">
                      <% if (awardsContent && awardsContent.length > 0) { %>
                        <% awardsContent.forEach(award => { %>
                        <tr>
                          <td><%= award.title %></td>
                          <td><%= award.organization || 'N/A' %></td>
                          <td><%= award.year || 'N/A' %></td>
                          <td><%= award.content ? award.content.substring(0, 50) + '...' : 'N/A' %></td>
                          <td>
                            <% if (award.featured) { %>
                              <span class="badge bg-success">Featured</span>
                            <% } else { %>
                              <span class="badge bg-secondary">Regular</span>
                            <% } %>
                          </td>
                          <td>
                            <button class="admin-btn admin-btn-warning admin-btn-sm me-1" onclick="editAwardItem(<%= award.id %>)" title="Edit Award">
                              <i class="fas fa-edit"></i>
                            </button>
                            <button class="admin-btn admin-btn-danger admin-btn-sm" onclick="deleteAwardItem(<%= award.id %>, '<%= award.title %>')" title="Delete Award">
                              <i class="fas fa-trash"></i>
                            </button>
                          </td>
                        </tr>
                        <% }); %>
                      <% } else { %>
                        <tr>
                          <td colspan="6" class="text-center py-4">
                            <i class="fas fa-trophy fa-2x text-muted mb-2"></i>
                            <p class="text-muted">No awards found</p>
                          </td>
                        </tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <!-- Add New Award -->
            <div class="admin-card">
              <div class="admin-card-header">
                <h5><i class="fas fa-plus me-2"></i>Add New Award</h5>
              </div>
              <div class="admin-card-body">
                <form action="/admin/awards-recognition" method="POST" enctype="multipart/form-data">
                  <div class="admin-form-group">
                    <label for="awardTitle" class="admin-form-label">Award Title *</label>
                    <input type="text" class="admin-form-control" id="awardTitle" name="title" required>
                  </div>
                  <div class="admin-form-group">
                    <label for="organization" class="admin-form-label">Organization</label>
                    <input type="text" class="admin-form-control" id="organization" name="organization">
                  </div>
                  <div class="admin-form-group">
                    <label for="year" class="admin-form-label">Year</label>
                    <input type="number" class="admin-form-control" id="year" name="year" min="1900" max="<%= new Date().getFullYear() %>">
                  </div>
                  <div class="admin-form-group">
                    <label for="awardContent" class="admin-form-label">Description *</label>
                    <textarea class="admin-form-control admin-form-textarea" id="awardContent" name="content" rows="4" required></textarea>
                  </div>
                  <div class="admin-form-group">
                    <label for="awardImage" class="admin-form-label">Award Image</label>
                    <input type="file" class="admin-form-control" id="awardImage" name="image" accept="image/*">
                  </div>
                  <div class="admin-form-group">
                    <div class="form-check">
                      <input type="checkbox" class="form-check-input" id="featured" name="featured" value="true">
                      <label class="form-check-label" for="featured">Featured Award</label>
                    </div>
                  </div>
                  <button type="submit" class="admin-btn admin-btn-primary w-100">Add Award</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function editAwardItem(id) {
      // For simplicity, we'll redirect to edit mode or use a simple prompt
      // In a real application, you'd fetch the data via AJAX
      const newTitle = prompt('Enter new award title:');
      const newContent = prompt('Enter new description:');

      if (newTitle && newContent) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/awards-recognition/edit/' + id;

        const titleInput = document.createElement('input');
        titleInput.type = 'hidden';
        titleInput.name = 'title';
        titleInput.value = newTitle;
        form.appendChild(titleInput);

        const contentInput = document.createElement('input');
        contentInput.type = 'hidden';
        contentInput.name = 'content';
        contentInput.value = newContent;
        form.appendChild(contentInput);

        document.body.appendChild(form);
        form.submit();
      }
    }

    function deleteAwardItem(id, name) {
      if (confirm('Are you sure you want to delete "' + name + '"? This action cannot be undone.')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/awards-recognition/delete/' + id;
        document.body.appendChild(form);
        form.submit();
      }
    }

    // Search functionality
    document.getElementById('awardsSearch').addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      const rows = document.querySelectorAll('#awardsTableBody tr');

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
