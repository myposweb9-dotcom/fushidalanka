<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Mobile Menu Toggle Button -->
  <button id="adminMenuToggle" type="button" aria-label="Toggle navigation">
    <i class="fas fa-bars"></i>
  </button>

  <div class="d-flex">
    <!-- Sidebar -->
    <div class="admin-sidebar">
      <h4><i class="fas fa-cog"></i> Admin Panel</h4>
      <nav class="nav flex-column">
        <a href="/admin/dashboard" class="nav-link">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a href="/admin/products" class="nav-link">
          <i class="fas fa-box"></i> Products
        </a>
        <a href="/admin/categories" class="nav-link">
          <i class="fas fa-tags"></i> Categories
        </a>
        <a href="/admin/users" class="nav-link">
          <i class="fas fa-users"></i> Users
        </a>
        <a href="/admin/testimonials" class="nav-link">
          <i class="fas fa-star"></i> Testimonials
        </a>
        <a href="/admin/content" class="nav-link active">
          <i class="fas fa-edit"></i> Content
        </a>
        <a href="/admin/logout" class="nav-link">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-grow-12">
      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2><%= title %></h2>
            <p class="mb-0">Manage website content and pages</p>
          </div>
          <div class="d-flex align-items-center">
            <button class="admin-btn admin-btn-primary me-2" data-bs-toggle="modal" data-bs-target="#addContentModal">
              <i class="fas fa-plus me-1"></i>Add Content
            </button>
            <a href="/admin/dashboard" class="admin-btn admin-btn-secondary">
              <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
          </div>
        </div>
      </div>

      <div class="admin-content">

        <!-- Search and Filter -->
        <div class="admin-search mb-4">
          <input type="text" placeholder="Search content..." id="contentSearch">
          <i class="fas fa-search"></i>
        </div>

        <!-- Content Tabs -->
        <div class="admin-card">
          <div class="admin-card-header">
            <ul class="nav nav-tabs" id="contentTabs" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button" role="tab">General Content</button>
              </li>
            </ul>
          </div>
          <div class="admin-card-body">
            <div class="tab-content" id="contentTabsContent">
              <!-- General Content Tab -->
              <div class="tab-pane fade show active" id="general" role="tabpanel">
                <div class="table-responsive">
                  <table class="admin-table" id="contentTable">
                    <thead>
                      <tr>
                        <th>Type</th>
                        <th>Title</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="contentTableBody">
                      <% if (content && content.length > 0) { %>
                        <% content.forEach(item => { %>
                        <tr>
                          <td><%= item.type %></td>
                          <td><%= item.title || item.name %></td>
                          <td>
                            <button class="admin-btn admin-btn-primary admin-btn-sm me-1" onclick="editContent(<%= item.id %>)" data-type="<%= item.type %>" data-title="<%= (item.title || '').replace(/"/g, '"') %>" data-content="<%= (item.content || '').replace(/"/g, '"').replace(/\n/g, '\\n') %>">
                              <i class="fas fa-edit"></i>
                            </button>
                            <button class="admin-btn admin-btn-danger admin-btn-sm" onclick="deleteContent(<%= item.id %>, '<%= (item.title || item.name).replace(/'/g, "\\'") %>')">
                              <i class="fas fa-trash"></i>
                            </button>
                          </td>
                        </tr>
                        <% }); %>
                      <% } else { %>
                        <tr>
                          <td colspan="3" class="text-center py-4">
                            <i class="fas fa-inbox fa-2x text-muted mb-2"></i>
                            <p class="text-muted">No content found</p>
                          </td>
                        </tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>

              

                  <div class="col-md-4">
                    <!-- Add New Company -->
                    <div class="admin-card">
                      <div class="admin-card-header">
                        <h5><i class="fas fa-plus me-2"></i>Add New Company</h5>
                      </div>
                      <div class="admin-card-body">
                        <form action="/admin/content" method="POST" enctype="multipart/form-data">
                          <input type="hidden" name="type" value="group">
                          <div class="admin-form-group">
                            <label for="companyName" class="admin-form-label">Company Name *</label>
                            <input type="text" class="admin-form-control" id="companyName" name="title" required>
                          </div>
                          <div class="admin-form-group">
                            <label for="companyContent" class="admin-form-label">Description *</label>
                            <textarea class="admin-form-control admin-form-textarea" id="companyContent" name="content" rows="4" required></textarea>
                          </div>
                          <div class="admin-form-group">
                            <label for="companyLogo" class="admin-form-label">Company Logo</label>
                            <input type="file" class="admin-form-control" id="companyLogo" name="logo" accept="image/*">
                          </div>
                          <div class="admin-form-group">
                            <label for="companyBackground" class="admin-form-label">Background Image</label>
                            <input type="file" class="admin-form-control" id="companyBackground" name="backgroundImage" accept="image/*">
                          </div>
                          <div class="admin-form-group">
                            <label for="companyWebsite" class="admin-form-label">Website URL</label>
                            <input type="url" class="admin-form-control" id="companyWebsite" name="website" placeholder="https://example.com">
                          </div>
                          <div class="admin-form-group">
                            <div class="form-check">
                              <input type="checkbox" class="form-check-input" id="featured" name="featured" value="true">
                              <label class="form-check-label" for="featured">Featured Company</label>
                            </div>
                          </div>
                          <button type="submit" class="admin-btn admin-btn-primary w-100">Add Company</button>
                        </form>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

    <!-- Add Content Modal -->
    <div class="modal fade" id="addContentModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><i class="fas fa-plus me-2"></i>Add New Content</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
                <form action="/admin/content" method="POST" enctype="multipart/form-data">
            <div class="modal-body">
              <div class="row">
                <div class="col-md-6">
                  <div class="admin-form-group">
                    <label for="addContentType" class="admin-form-label">Content Type *</label>
                    <select class="admin-form-control" id="addContentType" name="type" required>
                      <option value="about">About</option>
                      <option value="service">Service</option>
                      <option value="testimonial">Testimonial</option>
                    </select>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="admin-form-group">
                    <label for="addContentTitle" class="admin-form-label">Title</label>
                    <input type="text" class="admin-form-control" id="addContentTitle" name="title">
                  </div>
                </div>
              </div>
              <div class="admin-form-group">
                <label for="addContentContent" class="admin-form-label">Content</label>
                <textarea class="admin-form-control admin-form-textarea" id="addContentContent" name="content" rows="5"></textarea>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="admin-btn admin-btn-primary">Add Content</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Edit Content Modal -->
    <div class="modal fade" id="editContentModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Edit Content</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <form id="editContentForm" method="POST">
            <div class="modal-body">
              <input type="hidden" id="editContentId" name="id">
              <div class="row">
                <div class="col-md-6">
                  <div class="admin-form-group">
                    <label for="editType" class="admin-form-label">Content Type *</label>
                    <select class="admin-form-control" id="editType" name="type" required>
                      <option value="about">About</option>
                      <option value="service">Service</option>
                      <option value="testimonial">Testimonial</option>
                    </select>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="admin-form-group">
                    <label for="editTitle" class="admin-form-label">Title</label>
                    <input type="text" class="admin-form-control" id="editTitle" name="title">
                  </div>
                </div>
              </div>
              <div class="admin-form-group">
                <label for="editContent" class="admin-form-label">Content</label>
                <textarea class="admin-form-control admin-form-textarea" id="editContent" name="content" rows="5"></textarea>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="admin-btn admin-btn-primary">Update Content</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Edit Group Company Modal -->
    <div class="modal fade" id="editGroupModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Edit Company</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <form id="editGroupForm" method="POST">
            <div class="modal-body">
              <input type="hidden" id="editGroupId" name="id">
              <div class="admin-form-group">
                <label for="editTitle" class="admin-form-label">Company Name *</label>
                <input type="text" class="admin-form-control" id="editTitle" name="title" required>
              </div>
              <div class="admin-form-group">
                <label for="editContent" class="admin-form-label">Description *</label>
                <textarea class="admin-form-control admin-form-textarea" id="editContent" name="content" rows="4" required></textarea>
              </div>
              <div class="admin-form-group">
                <label for="editLogo" class="admin-form-label">Company Logo</label>
                <input type="file" class="admin-form-control" id="editLogo" name="logo" accept="image/*">
              </div>
              <div class="admin-form-group">
                <label for="editBackground" class="admin-form-label">Background Image</label>
                <input type="file" class="admin-form-control" id="editBackground" name="backgroundImage" accept="image/*">
              </div>
              <div class="admin-form-group">
                <label for="editWebsite" class="admin-form-label">Website URL</label>
                <input type="url" class="admin-form-control" id="editWebsite" name="website" placeholder="https://example.com">
              </div>
              <div class="admin-form-group">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="editFeatured" name="featured" value="true">
                  <label class="form-check-label" for="editFeatured">Featured Company</label>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="admin-btn admin-btn-primary">Update Company</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function editContent(id) {
      // Find all edit buttons and check which one matches the ID
      const editButtons = document.querySelectorAll('button[onclick*="editContent("]');

      for (let btn of editButtons) {
        if (btn.getAttribute('onclick').includes('editContent(' + id + ')')) {
          const type = btn.getAttribute('data-type');
          const title = btn.getAttribute('data-title').replace(/"/g, '"');
          const content = btn.getAttribute('data-content').replace(/"/g, '"').replace(/\\n/g, '\n');

          document.getElementById('editContentId').value = id;
          document.getElementById('editType').value = type;
          document.getElementById('editTitle').value = title || '';
          document.getElementById('editContent').value = content || '';
          document.getElementById('editContentForm').action = '/admin/content/edit/' + id;

          const modal = new bootstrap.Modal(document.getElementById('editContentModal'));
          modal.show();
          return;
        }
      }

      alert('Content data not found');
    }

    function deleteContent(id, name) {
      if (confirm(`Are you sure you want to delete the content "${name}"? This action cannot be undone.`)) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/content/delete/' + id;
        document.body.appendChild(form);
        form.submit();
      }
    }

    function editGroupItem(id) {
      // For simplicity, we'll redirect to edit mode or use a simple prompt
      // In a real application, you'd fetch the data via AJAX
      const newTitle = prompt('Enter new company name:');
      const newContent = prompt('Enter new description:');

      if (newTitle && newContent) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/content/edit/' + id;

        const titleInput = document.createElement('input');
        titleInput.type = 'hidden';
        titleInput.name = 'title';
        titleInput.value = newTitle;
        form.appendChild(titleInput);

        const contentInput = document.createElement('input');
        contentInput.type = 'hidden';
        contentInput.name = 'content';
        contentInput.value = newContent;
        form.appendChild(contentInput);

        document.body.appendChild(form);
        form.submit();
      }
    }

    function deleteGroupItem(id, name) {
      if (confirm('Are you sure you want to delete "' + name + '"? This action cannot be undone.')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/content/delete/' + id;
        document.body.appendChild(form);
        form.submit();
      }
    }

    // Search functionality for general content
    document.getElementById('contentSearch').addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      const rows = document.querySelectorAll('#contentTableBody tr');

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });

    // Search functionality for group companies
    document.getElementById('groupSearch').addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      const rows = document.querySelectorAll('#groupTableBody tr');

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
