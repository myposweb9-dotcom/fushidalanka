<%- include('../partials/admin-header') %>

<div class="container-fluid">
  <div class="row">
    <!-- Sidebar -->
    <%- include('../partials/admin-sidebar') %>

    <!-- Main Content -->
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Manage Logos</h1>
        <div class="btn-toolbar mb-2 mb-md-0">
          <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addLogoModal">
            <i class="fas fa-plus"></i> Add Logo
          </button>
        </div>
      </div>

      <!-- Flash Messages -->
      <% if (messages && messages.error && messages.error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= messages.error[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <% if (messages && messages.success && messages.success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= messages.success[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Logos Table -->
      <div class="card">
        <div class="card-header">
          <h5 class="card-title mb-0">Logos List</h5>
        </div>
        <div class="card-body">
          <% if (logos && logos.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr>
                    <th>Order</th>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Content</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% logos.forEach(logo => { %>
                    <tr>
                      <td><%= logo.order %></td>
                      <td>
                        <% if (logo.image) { %>
                          <img src="<%= logo.image %>" alt="<%= logo.title || 'Logo' %>" style="max-width: 50px; max-height: 50px;">
                        <% } else { %>
                          <span class="text-muted">No image</span>
                        <% } %>
                      </td>
                      <td><%= logo.title || '-' %></td>
                      <td><%= logo.content ? logo.content.substring(0, 50) + (logo.content.length > 50 ? '...' : '') : '-' %></td>
                      <td>
                        <span class="badge <%= logo.isActive ? 'bg-success' : 'bg-secondary' %>">
                          <%= logo.isActive ? 'Active' : 'Inactive' %>
                        </span>
                      </td>
                      <td>
                        <div class="btn-group" role="group">
                          <button type="button" class="btn btn-sm btn-outline-primary edit-logo-btn"
                                  data-id="<%= logo.id %>"
                                  data-title="<%= logo.title || '' %>"
                                  data-content="<%= logo.content || '' %>"
                                  data-order="<%= logo.order %>"
                                  data-image="<%= logo.image || '' %>"
                                  data-bs-toggle="modal"
                                  data-bs-target="#editLogoModal">
                            <i class="fas fa-edit"></i> Edit
                          </button>
                          <button type="button" class="btn btn-sm btn-outline-danger delete-logo-btn"
                                  data-id="<%= logo.id %>"
                                  data-title="<%= logo.title || 'this logo' %>">
                            <i class="fas fa-trash"></i> Delete
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="fas fa-image fa-3x text-muted mb-3"></i>
              <h5 class="text-muted">No logos found</h5>
              <p class="text-muted">Start by adding your first logo to the scrolling bar.</p>
              <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addLogoModal">
                <i class="fas fa-plus"></i> Add First Logo
              </button>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>
</div>

<!-- Add Logo Modal -->
<div class="modal fade" id="addLogoModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add New Logo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/logos" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label for="addLogoTitle" class="form-label">Title (Optional)</label>
                <input type="text" class="form-control" id="addLogoTitle" name="title" placeholder="Logo title">
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label for="addLogoOrder" class="form-label">Display Order</label>
                <input type="number" class="form-control" id="addLogoOrder" name="order" value="0" min="0">
              </div>
            </div>
          </div>
          <div class="mb-3">
            <label for="addLogoContent" class="form-label">Description (Optional)</label>
            <textarea class="form-control" id="addLogoContent" name="content" rows="3" placeholder="Brief description"></textarea>
          </div>
          <div class="mb-3">
            <label for="addLogoImage" class="form-label">Logo Image *</label>
            <input type="file" class="form-control" id="addLogoImage" name="image" accept="image/*" required>
            <div class="form-text">Upload a logo image (PNG, JPG, SVG recommended)</div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Logo</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Logo Modal -->
<div class="modal fade" id="editLogoModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Logo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="editLogoForm" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label for="editLogoTitle" class="form-label">Title (Optional)</label>
                <input type="text" class="form-control" id="editLogoTitle" name="title" placeholder="Logo title">
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label for="editLogoOrder" class="form-label">Display Order</label>
                <input type="number" class="form-control" id="editLogoOrder" name="order" value="0" min="0">
              </div>
            </div>
          </div>
          <div class="mb-3">
            <label for="editLogoContent" class="form-label">Description (Optional)</label>
            <textarea class="form-control" id="editLogoContent" name="content" rows="3" placeholder="Brief description"></textarea>
          </div>
          <div class="mb-3">
            <label for="editLogoImage" class="form-label">Logo Image</label>
            <input type="file" class="form-control" id="editLogoImage" name="image" accept="image/*">
            <div class="form-text">Leave empty to keep current image</div>
            <div id="currentImageContainer" class="mt-2" style="display: none;">
              <img id="currentLogoImage" src="" alt="Current logo" style="max-width: 100px; max-height: 100px;">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Update Logo</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteLogoModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Delete Logo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to delete <strong id="deleteLogoTitle"></strong>?</p>
        <p class="text-danger">This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
      </div>
    </div>
  </div>
</div>

<script>
// Edit Logo Modal Handler
document.querySelectorAll('.edit-logo-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const id = this.getAttribute('data-id');
    const title = this.getAttribute('data-title');
    const content = this.getAttribute('data-content');
    const order = this.getAttribute('data-order');
    const image = this.getAttribute('data-image');

    document.getElementById('editLogoForm').action = `/admin/logos/edit/${id}`;
    document.getElementById('editLogoTitle').value = title;
    document.getElementById('editLogoContent').value = content;
    document.getElementById('editLogoOrder').value = order;

    const imageContainer = document.getElementById('currentImageContainer');
    const imageElement = document.getElementById('currentLogoImage');

    if (image) {
      imageElement.src = image;
      imageContainer.style.display = 'block';
    } else {
      imageContainer.style.display = 'none';
    }
  });
});

// Delete Logo Modal Handler
document.querySelectorAll('.delete-logo-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const id = this.getAttribute('data-id');
    const title = this.getAttribute('data-title');

    document.getElementById('deleteLogoTitle').textContent = title;
    document.getElementById('confirmDeleteBtn').onclick = function() {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = `/admin/logos/delete/${id}`;

      document.body.appendChild(form);
      form.submit();
    };

    new bootstrap.Modal(document.getElementById('deleteLogoModal')).show();
  });
});
</script>

<script src="/js/main.js"></script>

<%- include('../partials/admin-footer') %>
