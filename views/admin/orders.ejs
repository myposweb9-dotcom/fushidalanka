<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Mobile Menu Toggle Button -->
  <button id="adminMenuToggle" class="btn btn-sm btn-light border rounded-circle" style="position: fixed; top: 20px; left: 20px; width: 44px; height: 44px; padding: 0; z-index: 1061;">
    <i class="fas fa-bars"></i>
  </button>

  <div class="d-flex">
    <!-- Sidebar -->
    <div class="admin-sidebar">
      <h4><i class="fas fa-cog"></i> Admin Panel</h4>
      <nav class="nav flex-column">
        <a href="/admin/dashboard" class="nav-link">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a href="/admin/products" class="nav-link">
          <i class="fas fa-box"></i> Products
        </a>
        <a href="/admin/categories" class="nav-link">
          <i class="fas fa-tags"></i> Categories
        </a>
        <a href="/admin/users" class="nav-link">
          <i class="fas fa-users"></i> Users
        </a>
        <a href="/admin/testimonials" class="nav-link">
          <i class="fas fa-star"></i> Testimonials
        </a>
        <a href="/admin/content" class="nav-link">
          <i class="fas fa-edit"></i> Content
        </a>
        <a href="/admin/logout" class="nav-link">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-grow-12">
      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2><%= title %></h2>
            <p class="mb-0">Manage customer orders and transactions</p>
          </div>
          <div class="d-flex align-items-center">
            <a href="/admin/dashboard" class="admin-btn admin-btn-secondary">
              <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
          </div>
        </div>
      </div>

      <div class="admin-content">
        <!-- Order Stats -->
        <div class="row mb-4">
          <div class="col-md-3">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-shopping-cart fa-2x text-primary mb-2"></i>
                <h4><%= (orders || []).length %></h4>
                <p class="text-muted mb-0">Total Orders</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-clock fa-2x text-warning mb-2"></i>
                <h4><%= (orders || []).filter(o => o.status === 'pending').length %></h4>
                <p class="text-muted mb-0">Pending Orders</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                <h4><%= (orders || []).filter(o => o.status === 'completed').length %></h4>
                <p class="text-muted mb-0">Completed Orders</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-dollar-sign fa-2x text-info mb-2"></i>
                <h4>LKR <%= (orders || []).filter(o => o.status === 'completed').reduce((sum, o) => sum + (o.total || 0), 0).toLocaleString() %></h4>
                <p class="text-muted mb-0">Total Revenue</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Search and Filter -->
        <div class="admin-search mb-4">
          <input type="text" placeholder="Search orders..." id="orderSearch">
          <i class="fas fa-search"></i>
        </div>

        <!-- Orders Table -->
        <div class="admin-card">
          <div class="admin-card-header">
            <h5><i class="fas fa-list me-2"></i>All Orders</h5>
          </div>
          <div class="admin-card-body">
            <div class="table-responsive">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Products</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="ordersTableBody">
                  <% if (orders && orders.length > 0) { %>
                    <% orders.forEach(order => { %>
                    <tr>
                      <td>#<%= order.id %></td>
                      <td><%= order.customer %></td>
                      <td><%= order.products %></td>
                      <td>LKR <%= order.total %></td>
                      <td>
                        <span class="badge bg-<%= order.status === 'completed' ? 'success' : order.status === 'pending' ? 'warning' : 'secondary' %>">
                          <%= order.status %>
                        </span>
                      </td>
                      <td><%= order.date %></td>
                      <td>
                        <button class="admin-btn admin-btn-primary admin-btn-sm me-1" onclick="viewOrder(<%= order.id %>)">
                          <i class="fas fa-eye"></i>
                        </button>
                        <button class="admin-btn admin-btn-success admin-btn-sm" onclick="updateOrderStatus(<%= order.id %>, '<%= order.status %>')">
                          <i class="fas fa-edit"></i>
                        </button>
                      </td>
                    </tr>
                    <% }); %>
                  <% } else { %>
                    <tr>
                      <td colspan="7" class="text-center py-4">
                        <i class="fas fa-shopping-cart fa-2x text-muted mb-2"></i>
                        <p class="text-muted">No orders found</p>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function viewOrder(id) {
      // Placeholder for viewing order details
      alert('View order details for Order #' + id);
    }

    function updateOrderStatus(id, currentStatus) {
      const newStatus = prompt('Update order status (pending/completed/cancelled):', currentStatus);
      if (newStatus && newStatus !== currentStatus) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/orders/update/' + id;
        const statusInput = document.createElement('input');
        statusInput.type = 'hidden';
        statusInput.name = 'status';
        statusInput.value = newStatus;
        form.appendChild(statusInput);
        document.body.appendChild(form);
        form.submit();
      }
    }

    // Search functionality
    document.getElementById('orderSearch').addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      const rows = document.querySelectorAll('#ordersTableBody tr');

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
