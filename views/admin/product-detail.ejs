<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="d-flex">
    <!-- Sidebar -->
    <div class="admin-sidebar">
      <h4><i class="fas fa-cog"></i> Admin Panel</h4>
      <nav class="nav flex-column">
        <a href="/admin/dashboard" class="nav-link">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a href="/admin/products" class="nav-link active">
          <i class="fas fa-box"></i> Products
        </a>
        <a href="/admin/categories" class="nav-link">
          <i class="fas fa-tags"></i> Categories
        </a>
        <a href="/admin/users" class="nav-link">
          <i class="fas fa-users"></i> Users
        </a>
        <a href="/admin/testimonials" class="nav-link">
          <i class="fas fa-star"></i> Testimonials
        </a>
        <a href="/admin/content" class="nav-link">
          <i class="fas fa-edit"></i> Content
        </a>
        <a href="/admin/logout" class="nav-link">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-grow-12">
      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2><i class="fas fa-eye me-2"></i>View Product</h2>
            <p class="mb-0">Product details and information</p>
          </div>
          <div class="d-flex align-items-center">
            <a href="/admin/products" class="admin-btn admin-btn-secondary me-2">
              <i class="fas fa-arrow-left me-1"></i>Back to Products
            </a>
            <button class="admin-btn admin-btn-primary" onclick="editProduct('<%= product.id %>')">
              <i class="fas fa-edit me-1"></i>Edit Product
            </button>
          </div>
        </div>
      </div>

      <div class="admin-content">
        <div class="row">
          <!-- Product Images -->
          <div class="col-lg-6">
            <div class="admin-card">
              <div class="admin-card-header">
                <h5><i class="fas fa-images me-2"></i>Product Images</h5>
              </div>
              <div class="admin-card-body">
                <% if (product.images && product.images.length > 0) { %>
                  <div class="row">
                    <% product.images.forEach((image, index) => { %>
                      <div class="col-md-6 mb-3">
                        <img src="<%= image %>" alt="<%= product.name %> - Image <%= index + 1 %>" class="img-fluid rounded shadow" onerror="this.onerror=null;this.src='https://via.placeholder.com/300x200?text=No+Image';">
                      </div>
                    <% }); %>
                  </div>
                <% } else { %>
                  <div class="text-center py-4">
                    <i class="fas fa-image fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No images uploaded</p>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Product Details -->
          <div class="col-lg-6">
            <div class="admin-card">
              <div class="admin-card-header">
                <h5><i class="fas fa-info-circle me-2"></i>Product Information</h5>
              </div>
              <div class="admin-card-body">
                <table class="table table-borderless">
                  <tr>
                    <td class="fw-bold">Product Name:</td>
                    <td><%= product.name %></td>
                  </tr>
                  <tr>
                    <td class="fw-bold">Category:</td>
                    <td>
                      <% if (product.category) { %>
                        <span class="badge bg-primary"><%= product.category.name %></span>
                      <% } else { %>
                        <span class="text-muted">N/A</span>
                      <% } %>
                    </td>
                  </tr>
                  <tr>
                    <td class="fw-bold">Price:</td>
                    <td class="fw-bold text-success">LKR <%= product.price %></td>
                  </tr>
                  <tr>
                    <td class="fw-bold">Stock:</td>
                    <td>
                      <span class="badge <%= product.stock > 0 ? 'bg-success' : 'bg-danger' %>">
                        <%= product.stock || 0 %> units
                      </span>
                    </td>
                  </tr>
                  <tr>
                    <td class="fw-bold">Status:</td>
                    <td>
                      <span class="badge bg-<%= product.status === 'active' ? 'success' : product.status === 'pending' ? 'warning' : 'secondary' %>">
                        <%= product.status || 'active' %>
                      </span>
                    </td>
                  </tr>
                  <tr>
                    <td class="fw-bold">Submitted By:</td>
                    <td>
                      <% if (product.user) { %>
                        <%= product.user.name %> (<%= product.user.email %>)
                      <% } else { %>
                        <span class="text-muted">Admin</span>
                      <% } %>
                    </td>
                  </tr>
                  <tr>
                    <td class="fw-bold">Created:</td>
                    <td><%= new Date(product.createdAt).toLocaleDateString() %></td>
                  </tr>
                  <tr>
                    <td class="fw-bold">Updated:</td>
                    <td><%= new Date(product.updatedAt).toLocaleDateString() %></td>
                  </tr>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Product Description -->
        <div class="admin-card">
          <div class="admin-card-header">
            <h5><i class="fas fa-align-left me-2"></i>Description</h5>
          </div>
          <div class="admin-card-body">
            <% if (product.description) { %>
              <div class="text-dark"><%- product.description %></div>
            <% } else { %>
              <p class="text-muted">No description provided</p>
            <% } %>
          </div>
        </div>

        <!-- Specifications -->
        <% if (product.specifications) { %>
          <div class="admin-card">
            <div class="admin-card-header">
              <h5><i class="fas fa-list me-2"></i>Specifications</h5>
            </div>
            <div class="admin-card-body">
              <div class="table-responsive">
                <table class="table table-striped">
                  <tbody>
                    <% Object.entries(product.specifications).forEach(([key, value]) => { %>
                      <tr>
                        <td class="fw-bold"><%= key %></td>
                        <td><%= value %></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% } %>

        <!-- Datasheet -->
        <% if (product.datasheet) { %>
          <div class="admin-card">
            <div class="admin-card-header">
              <h5><i class="fas fa-file-pdf me-2"></i>Datasheet</h5>
            </div>
            <div class="admin-card-body">
              <a href="<%= product.datasheet %>" class="btn btn-outline-primary" target="_blank">
                <i class="fas fa-download me-2"></i>Download Datasheet
              </a>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function editProduct(productId) {
      // Redirect to edit modal or page
      window.location.href = '/admin/products?edit=' + productId;
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
