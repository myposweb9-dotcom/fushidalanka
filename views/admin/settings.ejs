<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Mobile Menu Toggle Button -->
  <button id="adminMenuToggle" type="button" aria-label="Toggle navigation">
    <i class="fas fa-bars"></i>
  </button>

  <div class="d-flex">
    <!-- Sidebar -->
    <div class="admin-sidebar">
      <h4><i class="fas fa-cog"></i> Admin Panel</h4>
      <nav class="nav flex-column">
        <a href="/admin/dashboard" class="nav-link">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a href="/admin/products" class="nav-link">
          <i class="fas fa-box"></i> Products
        </a>
        <a href="/admin/categories" class="nav-link">
          <i class="fas fa-tags"></i> Categories
        </a>
        <a href="/admin/users" class="nav-link">
          <i class="fas fa-users"></i> Users
        </a>
        <a href="/admin/testimonials" class="nav-link">
          <i class="fas fa-star"></i> Testimonials
        </a>
        <a href="/admin/team" class="nav-link">
          <i class="fas fa-users-cog"></i> Team
        </a>
        <a href="/admin/projects" class="nav-link">
          <i class="fas fa-project-diagram"></i> Projects
        </a>
        <a href="/admin/news" class="nav-link">
          <i class="fas fa-newspaper"></i> News
        </a>
        <a href="/admin/enquiries" class="nav-link">
          <i class="fas fa-envelope"></i> Enquiries
        </a>
        <a href="/admin/content" class="nav-link">
          <i class="fas fa-edit"></i> Content
        </a>
        <a href="/admin/settings" class="nav-link active">
          <i class="fas fa-cogs"></i> Settings
        </a>
        <a href="/admin/logout" class="nav-link">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-grow-1">
      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2><%= title %></h2>
            <p class="mb-0">Manage website settings and branding</p>
          </div>
          <div class="d-flex align-items-center">
            <a href="/admin/dashboard" class="admin-btn admin-btn-secondary">
              <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
          </div>
        </div>
      </div>

      <div class="admin-content">
        <!-- Logo Settings -->
        <div class="admin-card">
          <div class="admin-card-header">
            <h5><i class="fas fa-image me-2"></i>Logo Settings</h5>
          </div>
          <div class="admin-card-body">
            <div class="row">
              <div class="col-md-6">
                <div class="mb-4">
                  <h6 class="mb-3">Current Logo</h6>
                  <div class="current-logo-preview mb-3">
                    <img src="/images/FushidaLankaLogo.png" alt="Current Logo" class="img-fluid rounded shadow" style="max-height: 100px; max-width: 200px;">
                  </div>
                  <p class="text-muted small">Current logo is displayed in the navigation bar</p>
                </div>
              </div>
              <div class="col-md-6">
                <div class="mb-4">
                  <h6 class="mb-3">Upload New Logo</h6>
                  <form action="/admin/settings/logo" method="POST" enctype="multipart/form-data">
                    <div class="admin-form-group">
                      <label class="admin-form-label">Logo Image *</label>
                      <input type="file" class="admin-form-control" name="logo" accept="image/*" required>
                      <small class="form-text text-muted">
                        Recommended: PNG or SVG format, max 2MB, transparent background preferred
                      </small>
                    </div>
                    <div class="mt-3">
                      <button type="submit" class="admin-btn admin-btn-primary">
                        <i class="fas fa-upload me-1"></i>Upload Logo
                      </button>
                      <% if (typeof logo !== 'undefined' && logo) { %>
                        <button type="button" class="admin-btn admin-btn-danger ms-2" onclick="removeLogo()">
                          <i class="fas fa-trash me-1"></i>Remove Logo
                        </button>
                      <% } %>
                    </div>
                  </form>
                </div>
              </div>
            </div>

            <!-- Logo Preview -->
            <div class="mt-4">
              <h6 class="mb-3">Logo Preview</h6>
              <div class="border rounded p-3 bg-light">
                <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom" style="min-height: 60px;">
                  <div class="container-fluid px-4">
                    <a class="navbar-brand d-flex align-items-center" href="/">
                      <img src="/images/FushidaLankaLogo.png" alt="FushidaLanka Logo" class="navbar-logo me-2" style="height: 50px; width: auto; max-width: 280px; object-fit: contain;">
                      <div class="d-flex flex-column">
                        <span class="fw-bold text-dark mb-0" style="font-size: 1.1rem; line-height: 1;">FushidaLanka</span>
                        <small class="text-muted" style="font-size: 0.65rem; line-height: 1;">Solar Solutions</small>
                      </div>
                    </a>
                  </div>
                </nav>
              </div>
              <small class="text-muted mt-2 d-block">This is how your logo will appear in the navigation bar</small>
            </div>
          </div>
        </div>

        <!-- General Settings -->
        <div class="admin-card mt-4">
          <div class="admin-card-header">
            <h5><i class="fas fa-sliders-h me-2"></i>General Settings</h5>
          </div>
          <div class="admin-card-body">
            <p class="text-muted">Additional settings will be available here in future updates.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Remove Logo Modal -->
  <div class="modal fade" id="removeLogoModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-trash me-2"></i>Remove Logo</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p>Are you sure you want to remove the current logo? The default FushidaLanka branding will be displayed instead.</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <form action="/admin/settings/logo/remove" method="POST" style="display: inline;">
            <button type="submit" class="admin-btn admin-btn-danger">
              <i class="fas fa-trash me-1"></i>Remove Logo
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function removeLogo() {
      const modal = new bootstrap.Modal(document.getElementById('removeLogoModal'));
      modal.show();
    }

    // File input validation
    document.querySelector('input[name="logo"]').addEventListener('change', function(e) {
      const file = e.target.files[0];
      if (file) {
        // Check file size (2MB limit)
        if (file.size > 2 * 1024 * 1024) {
          alert('File size must be less than 2MB');
          e.target.value = '';
          return;
        }

        // Check file type
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/svg+xml', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
          alert('Please select a valid image file (JPEG, PNG, SVG, or WebP)');
          e.target.value = '';
          return;
        }
      }
    });
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
