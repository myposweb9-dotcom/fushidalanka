<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="d-flex">
    <!-- Sidebar -->
    <div class="admin-sidebar">
      <h4><i class="fas fa-cog"></i> Admin Panel</h4>
      <nav class="nav flex-column">
        <a href="/admin/dashboard" class="nav-link">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a href="/admin/products" class="nav-link">
          <i class="fas fa-box"></i> Products
        </a>
        <a href="/admin/categories" class="nav-link">
          <i class="fas fa-tags"></i> Categories
        </a>
        <a href="/admin/users" class="nav-link">
          <i class="fas fa-users"></i> Users
        </a>
        <a href="/admin/testimonials" class="nav-link active">
          <i class="fas fa-star"></i> Testimonials
        </a>
        <a href="/admin/content" class="nav-link">
          <i class="fas fa-edit"></i> Content
        </a>
        <a href="/admin/logout" class="nav-link">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-grow-12">
      <div class="admin-header">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2><%= title %></h2>
            <p class="mb-0">Manage customer testimonials and reviews</p>
          </div>
          <div class="d-flex align-items-center">
            <a href="/admin/dashboard" class="admin-btn admin-btn-secondary">
              <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
            </a>
          </div>
        </div>
      </div>

      <div class="admin-content">
        <!-- Testimonial Stats -->
        <div class="row mb-4">
          <div class="col-md-4">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-star fa-2x text-warning mb-2"></i>
                <h4><%= (testimonials || []).length %></h4>
                <p class="text-muted mb-0">Total Testimonials</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-star-half-alt fa-2x text-info mb-2"></i>
                <h4><%= (testimonials || []).filter(t => t.featured).length %></h4>
                <p class="text-muted mb-0">Featured Testimonials</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="admin-card">
              <div class="admin-card-body text-center">
                <i class="fas fa-chart-line fa-2x text-success mb-2"></i>
                <h4><%= (testimonials || []).length > 0 ? (testimonials.reduce((sum, t) => sum + (t.rating || 5), 0) / testimonials.length).toFixed(1) : 0 %></h4>
                <p class="text-muted mb-0">Average Rating</p>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-8">
            <!-- Search and Filter -->
            <div class="admin-search mb-4">
              <input type="text" placeholder="Search testimonials..." id="testimonialSearch">
              <i class="fas fa-search"></i>
            </div>

            <!-- Existing Testimonials -->
            <div class="admin-card">
              <div class="admin-card-header">
                <h5><i class="fas fa-list me-2"></i>All Testimonials</h5>
              </div>
              <div class="admin-card-body">
                <div class="table-responsive">
                  <table class="admin-table">
                    <thead>
                      <tr>
                        <th>Customer</th>
                        <th>Company</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody id="testimonialsTableBody">
                      <% if (testimonials && testimonials.length > 0) { %>
                        <% testimonials.forEach(testimonial => { %>
                        <tr>
                          <td><%= testimonial.title %></td>
                          <td><%= testimonial.company || 'N/A' %></td>
                          <td>
                            <% for (let i = 0; i < (testimonial.rating || 5); i++) { %>
                              <i class="fas fa-star text-warning"></i>
                            <% } %>
                          </td>
                          <td>
                            <% if (testimonial.featured) { %>
                              <span class="badge bg-success">Featured</span>
                            <% } else { %>
                              <span class="badge bg-secondary">Regular</span>
                            <% } %>
                          </td>
                          <td>
                            <button class="admin-btn admin-btn-warning admin-btn-sm me-1" onclick="editTestimonial(<%= testimonial.id %>)" title="Edit Testimonial">
                              <i class="fas fa-edit"></i>
                            </button>
                            <button class="admin-btn admin-btn-danger admin-btn-sm" onclick="deleteTestimonial(<%= testimonial.id %>, '<%= testimonial.title %>')" title="Delete Testimonial">
                              <i class="fas fa-trash"></i>
                            </button>
                          </td>
                        </tr>
                        <% }); %>
                      <% } else { %>
                        <tr>
                          <td colspan="5" class="text-center py-4">
                            <i class="fas fa-star fa-2x text-muted mb-2"></i>
                            <p class="text-muted">No testimonials found</p>
                          </td>
                        </tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-4">
            <!-- Add New Testimonial -->
            <div class="admin-card">
              <div class="admin-card-header">
                <h5><i class="fas fa-plus me-2"></i>Add New Testimonial</h5>
              </div>
              <div class="admin-card-body">
                <form action="/admin/testimonials" method="POST" enctype="multipart/form-data">
                  <div class="admin-form-group">
                    <label for="customerName" class="admin-form-label">Customer Name *</label>
                    <input type="text" class="admin-form-control" id="customerName" name="title" required>
                  </div>
                  <div class="admin-form-group">
                    <label for="company" class="admin-form-label">Company</label>
                    <input type="text" class="admin-form-control" id="company" name="company">
                  </div>
                  <div class="admin-form-group">
                    <label for="position" class="admin-form-label">Position</label>
                    <input type="text" class="admin-form-control" id="position" name="position">
                  </div>
                  <div class="admin-form-group">
                    <label for="rating" class="admin-form-label">Rating *</label>
                    <select class="admin-form-control" id="rating" name="rating" required>
                      <option value="5">5 Stars</option>
                      <option value="4">4 Stars</option>
                      <option value="3">3 Stars</option>
                      <option value="2">2 Stars</option>
                      <option value="1">1 Star</option>
                    </select>
                  </div>
                  <div class="admin-form-group">
                    <label for="testimonialContent" class="admin-form-label">Testimonial Text *</label>
                    <textarea class="admin-form-control admin-form-textarea" id="testimonialContent" name="content" rows="4" required></textarea>
                  </div>
                  <div class="admin-form-group">
                    <label for="imageUrl" class="admin-form-label">Image URL</label>
                    <input type="url" class="admin-form-control" id="imageUrl" name="image">
                  </div>
                  <div class="admin-form-group">
                    <div class="form-check">
                      <input type="checkbox" class="form-check-input" id="featured" name="featured" value="true">
                      <label class="form-check-label" for="featured">Featured on Homepage</label>
                    </div>
                  </div>
                  <button type="submit" class="admin-btn admin-btn-primary w-100">Add Testimonial</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Testimonial Modal -->
  <div class="modal fade" id="editTestimonialModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Edit Testimonial</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="editTestimonialForm" method="POST">
          <div class="modal-body">
            <input type="hidden" id="editTestimonialId" name="id">
            <div class="admin-form-group">
              <label for="editTitle" class="admin-form-label">Customer Name *</label>
              <input type="text" class="admin-form-control" id="editTitle" name="title" required>
            </div>
            <div class="admin-form-group">
              <label for="editCompany" class="admin-form-label">Company</label>
              <input type="text" class="admin-form-control" id="editCompany" name="company">
            </div>
            <div class="admin-form-group">
              <label for="editPosition" class="admin-form-label">Position</label>
              <input type="text" class="admin-form-control" id="editPosition" name="position">
            </div>
            <div class="admin-form-group">
              <label for="editRating" class="admin-form-label">Rating *</label>
              <select class="admin-form-control" id="editRating" name="rating" required>
                <option value="5">5 Stars</option>
                <option value="4">4 Stars</option>
                <option value="3">3 Stars</option>
                <option value="2">2 Stars</option>
                <option value="1">1 Star</option>
              </select>
            </div>
            <div class="admin-form-group">
              <label for="editContent" class="admin-form-label">Testimonial Text *</label>
              <textarea class="admin-form-control admin-form-textarea" id="editContent" name="content" rows="4" required></textarea>
            </div>
            <div class="admin-form-group">
              <label for="editImage" class="admin-form-label">Image URL</label>
              <input type="url" class="admin-form-control" id="editImage" name="image">
            </div>
            <div class="admin-form-group">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" id="editFeatured" name="featured" value="true">
                <label class="form-check-label" for="editFeatured">Featured on Homepage</label>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="admin-btn admin-btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="admin-btn admin-btn-primary">Update Testimonial</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function editTestimonial(id) {
      // Fetch testimonial data via AJAX
      fetch('/admin/testimonials/' + id)
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            const testimonial = data.testimonial;

            // Populate the edit modal with testimonial data
            document.getElementById('editTestimonialId').value = testimonial.id;
            document.getElementById('editTitle').value = testimonial.title;
            document.getElementById('editCompany').value = testimonial.company || '';
            document.getElementById('editPosition').value = testimonial.position || '';
            document.getElementById('editRating').value = testimonial.rating || 5;
            document.getElementById('editContent').value = testimonial.content;
            document.getElementById('editImage').value = testimonial.image || '';
            document.getElementById('editFeatured').checked = testimonial.featured;

            // Set the form action
            document.getElementById('editTestimonialForm').action = '/admin/testimonials/edit/' + id;

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('editTestimonialModal'));
            modal.show();
          } else {
            alert('Failed to load testimonial data: ' + data.message);
          }
        })
        .catch(error => {
          console.error('Error fetching testimonial:', error);
          alert('Failed to load testimonial data. Please try again.');
        });
    }

    function deleteTestimonial(id, name) {
      if (confirm(`Are you sure you want to delete the testimonial from "${name}"? This action cannot be undone.`)) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/testimonials/delete/' + id;
        document.body.appendChild(form);
        form.submit();
      }
    }

    // Search functionality
    document.getElementById('testimonialSearch').addEventListener('input', function() {
      const searchTerm = this.value.toLowerCase();
      const rows = document.querySelectorAll('#testimonialsTableBody tr');

      rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(searchTerm) ? '' : 'none';
      });
    });
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
