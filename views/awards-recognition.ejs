<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Awards & Recognition - FushidaLanka' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header_new') %>

  <!-- Hero Section -->
  <section class="hero-section">
    <video autoplay loop muted playsinline class="hero-background-video">
      <source src="/images/vdo123.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
    <div class="hero-overlay"></div>
    <div class="container position-relative">
      <div class="row align-items-center justify-content-center">
        <div class="col-lg-8 text-center">
          <h1 class="display-4 fw-bold mb-4 text-white">Awards & Recognition</h1>
          <p class="lead mb-4 text-white-75">Celebrating excellence in renewable energy innovation and customer satisfaction.</p>
          <a href="#awards" class="btn btn-light btn-lg">Our Achievements</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Awards Section -->
  <section id="awards" class="py-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center">
          <h2 class="mb-4">Industry Recognition</h2>
          <p class="lead mb-4">Our commitment to excellence has been recognized by industry leaders and organizations worldwide.</p>
        </div>
      </div>
      <div class="row">
        <div class="col-lg-4 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-4">
              <i class="fas fa-trophy text-warning fa-3x mb-3"></i>
              <h4 class="card-title">Best Solar Installer 2023</h4>
              <p class="card-text">Awarded by the National Renewable Energy Association for outstanding installation quality and customer service.</p>
              <small class="text-muted">2023</small>
            </div>
          </div>
        </div>
        <div class="col-lg-4 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-4">
              <i class="fas fa-star text-success fa-3x mb-3"></i>
              <h4 class="card-title">Innovation Excellence</h4>
              <p class="card-text">Recognized for pioneering smart grid integration and IoT-based energy management solutions.</p>
              <small class="text-muted">2022</small>
            </div>
          </div>
        </div>
        <div class="col-lg-4 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-4">
              <i class="fas fa-certificate text-primary fa-3x mb-3"></i>
              <h4 class="card-title">Sustainability Champion</h4>
              <p class="card-text">Honored for reducing carbon emissions through large-scale solar installations across the region.</p>
              <small class="text-muted">2022</small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications Section -->
  <section class="py-5 bg-light">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center mb-5">
          <h2>Certifications & Standards</h2>
          <p class="lead">We maintain the highest industry standards and certifications to ensure quality and reliability.</p>
        </div>
      </div>
      <div class="row">
        <div class="col-lg-3 col-md-6 mb-4">
          <div class="card h-100 border-0 shadow text-center">
            <div class="card-body p-4">
              <i class="fas fa-shield-alt text-success fa-3x mb-3"></i>
              <h5 class="card-title">ISO 9001</h5>
              <p class="card-text">Quality Management Systems certification.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <div class="card h-100 border-0 shadow text-center">
            <div class="card-body p-4">
              <i class="fas fa-leaf text-primary fa-3x mb-3"></i>
              <h5 class="card-title">ISO 14001</h5>
              <p class="card-text">Environmental Management Systems certification.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <div class="card h-100 border-0 shadow text-center">
            <div class="card-body p-4">
              <i class="fas fa-hard-hat text-warning fa-3x mb-3"></i>
              <h5 class="card-title">OHSAS 18001</h5>
              <p class="card-text">Occupational Health and Safety Management Systems.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <div class="card h-100 border-0 shadow text-center">
            <div class="card-body p-4">
              <i class="fas fa-award text-info fa-3x mb-3"></i>
              <h5 class="card-title">NABCEP</h5>
              <p class="card-text">North American Board of Certified Energy Practitioners.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
<style>
  .hero-section {
    position: relative;
    height: 60vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background-color: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .hero-section .container {
    z-index: 2;
  }
</style>
  <script src="/js/main.js"></script>
</body>
