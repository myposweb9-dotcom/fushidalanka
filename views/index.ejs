        font-size: 1.1rem;
      }
    }

    @media (max-width: 576px) {
      .categories-grid {
        grid-template-columns: 1fr;
      }

      .category-card {
        padding: 1.25rem;
      }

      .category-icon {
        font-size: 2.2rem;
      }

      .category-title {
        font-size: 1rem;
      }
    }
  </style>
</body>
