<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="description" content="FushidaLanka Hardware - Premium tools, building materials, and hardware solutions. Best prices, expert service, and quality guaranteed.">
  <meta name="keywords" content="hardware shop, tools, building materials, hardware supplies, tools online, colombo hardware">
</head>
<body>
  <!-- Flying Solar Components -->
  <div class="flying-components" id="flying-components">
    <!-- Components will be loaded dynamically -->
  </div>
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero-section">
    <video muted playsinline class="hero-background-video" id="heroVideo">
      <source src="/images/vdo123.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
    <div class="hero-overlay" style="background-color: rgba(0, 0, 0, 0.2);"></div>
    <div class="container position-relative">
      <div class="row align-items-center justify-content-centers">
        <div class="col-lg-8 text-start">
          <div class="typing-container mb-4">
            <h1 class="display-4 fw-bold text-white typing-text" id="typingText"></h1>
          </div>
          <p class="lead mb-4 text-white-75">
            Your trusted destination for premium tools, building materials, and hardware solutions. Quality products, expert service, and unbeatable prices since 2010.
          </p>
          <div class="d-flex flex-column flex-sm-row gap-3">
            <a href="#products-section" class="btn btn-hero btn-lg">Shop Now</a>
            <a href="/contact" class="btn btn-outline-light btn-lg">Get Help</a>
            <a href="tel:+94773705820" class="btn btn-outline-light btn-lg">Call Now</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section" style="background: linear-gradient(135deg, #f0f5f2 0%, #e8f1eb 100%); padding: 80px 0;">
    <div class="container">
      <div class="row text-center mb-5">
        <div class="col-12">
          <h2 class="section-title" style="font-size: 2.5rem;">Why Choose FushidaLanka?</h2>
          <p class="text-muted" style="font-size: 1.1rem;">Premium quality, competitive prices, and exceptional customer service for all your hardware needs.</p>
        </div>
      </div>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100 border-0 shadow-md" style="border-top: 4px solid #1F3D24; transition: all 0.3s ease;">
