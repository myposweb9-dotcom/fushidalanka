          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products Section -->
  <section class="section" id="products-section" style="background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%); padding: 100px 0;">
    <div class="container">
      <div class="row text-center mb-5">
        <div class="col-12">
          <h2 class="section-title" style="font-size: 2.5rem;">Our Products & Categories</h2>
          <p class="text-muted" style="font-size: 1.1rem;">Browse our collection of premium tools, materials, and equipment for all your projects.</p>
        </div>
      </div>

      <!-- Shop by Category Section -->
      <div style="background: linear-gradient(135deg, #1F3D24 0%, #0F1F13 100%); padding: 60px 0; margin: 0 -9999px; padding-left: calc(9999px + 0); padding-right: calc(9999px + 0);">
        <div class="container">
          <div class="text-center mb-5">
            <h3 class="section-title" style="font-size: 2rem; color: white;">Shop by Category</h3>
          </div>
          <div class="categories-grid" id="categories-grid">
            <!-- Categories will be loaded dynamically -->
          </div>
        </div>
      </div>

      <!-- Featured Products Grid -->
      <div class="text-center mb-4">
        <h3 id="selected-category-title" class="mb-4" style="display: none; font-size: 1.8rem;"></h3>
      </div>
      <div class="row g-4" id="products-grid">
        <% if (featuredProducts && featuredProducts.length > 0) { %>
          <% featuredProducts.slice(0, 12).forEach((product, index) => { %>
            <div class="col-lg-4 col-md-6">
              <% const delay = index < 3 ? (index * 0.1).toFixed(1) : '0'; %>
              <div class="card h-100 product-card shadow-md" style="border: 1px solid rgba(31, 61, 36, 0.1); transition: all 0.3s ease; animation: slideInUp 0.6s ease-out <%= delay %>s;">
                <div class="position-relative overflow-hidden" style="height: 220px; background: linear-gradient(135deg, #e8f1eb 0%, #d4e8dc 100%);">
                  <% if (product.images && product.images.length > 0) { %>
                    <img src="<%= product.images[0] %>" class="card-img-top" alt="<%= product.name %>" style="height: 100%; width: 100%; object-fit: cover; transition: transform 0.4s ease;">
                  <% } else { %>
                    <div style="height: 100%; width: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem; color: rgba(31, 61, 36, 0.3);"><i class="fas fa-cube"></i></div>
                  <% } %>
                  <div class="position-absolute top-0 end-0 m-3">
                    <span class="badge" style="background: linear-gradient(135deg, #1F3D24, #ffffff); padding: 8px 12px; color: white; font-weight: 600;">NEW</span>
                  </div>
                </div>
                <div class="card-body d-flex flex-column" style="padding: 1.5rem;">
                  <h5 class="card-title fw-bold mb-2" style="color: #2c3e50; font-size: 1.1rem;"><%= product.name %></h5>
                  <p class="card-text text-muted" style="font-size: 0.9rem; line-height: 1.5;"><%= product.description ? product.description.substring(0, 70) + '...' : 'Premium quality product' %></p>
                  <div class="mt-auto pt-3">
                    <p class="gradient-text mb-3" style="font-size: 1.2rem; font-weight: 700; color: #1F3D24;">LKR <%= product.price ? product.price.toLocaleString('en-US') : 'Contact' %></p>
                    <a href="/products/<%= product.id %>" class="product-view-btn" style="width: 100%;">
                      <i class="fas fa-eye me-2"></i>View Details
                    </a>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>
  </section>

