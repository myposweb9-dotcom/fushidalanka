<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Our Partners - FushidaLanka' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero-section">
    <video autoplay loop muted playsinline class="hero-background-video">
      <source src="/images/vdo1234.mp4" type="video/mp4">
      Your browser does not support the video tag.
    </video>
    <div class="hero-overlay"></div>
    <div class="container position-relative">
      <div class="row align-items-center justify-content-center">
        <div class="col-lg-8 text-center">
          <h1 class="display-4 fw-bold mb-4 text-white">Our Partners</h1>
          <p class="lead mb-4 text-white-75">Trusted partnerships that drive innovation and excellence in renewable energy solutions.</p>
          <a href="#partners" class="btn btn-light btn-lg">Our Partners</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Partners Section -->
  <section id="partners" class="py-5">
    <div class="container">
      <div class="row">
        <div class="col-lg-8 mx-auto text-center">
          <h2 class="mb-4">Strategic Partnerships</h2>
          <p class="lead mb-4">We collaborate with industry leaders to deliver cutting-edge solar and renewable energy solutions.</p>
        </div>
      </div>
      <div class="row">
        <div class="col-lg-4 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-4">
              <i class="fas fa-industry text-primary fa-3x mb-3"></i>
              <h4 class="card-title">Technology Partners</h4>
              <p class="card-text">Leading manufacturers of solar panels, inverters, and energy storage systems.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-4">
              <i class="fas fa-university text-success fa-3x mb-3"></i>
              <h4 class="card-title">Research Institutions</h4>
              <p class="card-text">Collaborations with universities and research centers for innovation and development.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-4 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-4">
              <i class="fas fa-handshake text-warning fa-3x mb-3"></i>
              <h4 class="card-title">Industry Associations</h4>
              <p class="card-text">Active participation in industry associations and standards organizations.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Benefits Section -->
  <section class="py-5 bg-light">
    <div class="container">
      <div class="row">
        <div class="col-lg-6 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-5">
              <i class="fas fa-certificate text-primary fa-3x mb-3"></i>
              <h3 class="card-title">Quality Assurance</h3>
              <p class="card-text">Our partnerships ensure the highest quality standards and certifications for all our products and services.</p>
            </div>
          </div>
        </div>
        <div class="col-lg-6 mb-4">
          <div class="card h-100 border-0 shadow">
            <div class="card-body text-center p-5">
              <i class="fas fa-globe text-success fa-3x mb-3"></i>
              <h3 class="card-title">Global Reach</h3>
              <p class="card-text">International partnerships provide access to global markets and diverse expertise.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
<style>
  .hero-section {
    position: relative;
    height: 60vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 100%;
    background-color: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .hero-section .container {
    z-index: 2;
  }
</style>
  <script src="/js/main.js"></script>
</body>
