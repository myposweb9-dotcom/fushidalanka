<!-- Dashboard Header - Minimal Navigation -->
<nav class="navbar navbar-expand-lg navbar-light shadow-sm sticky-top" style="background: linear-gradient(135deg, rgba(255,255,255,0.95) 0%, rgba(248,250,255,0.95) 100%); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(102, 126, 234, 0.1);">
  <div class="container-fluid px-4">
    <!-- Admin Menu Toggle Button (Mobile) -->
    <button id="adminMenuToggle" class="btn btn-sm btn-light border rounded-circle me-2" style="display: none; width: 44px; height: 44px; padding: 0;">
      <i class="fas fa-bars"></i>
    </button>

    <!-- Logo Section -->
    <a class="navbar-brand d-flex align-items-center" href="/">
      <img src="/images/FushidaLankaLogo.png" alt="FushidaLanka Logo" class="navbar-logo me-2" style="height: 55px; width: auto; max-width: 350px; object-fit: contain;">
    </a>

    <!-- Mobile Toggle Button -->
    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#dashboardNavbar" aria-controls="dashboardNavbar" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Minimal User Authentication Section -->
    <div class="collapse navbar-collapse justify-content-end" id="dashboardNavbar">
      <ul class="navbar-nav d-flex">
        <% if (typeof user !== 'undefined' && user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle px-3 py-2 mx-1 rounded-pill text-dark fw-medium d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              <div class="user-avatar me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; color: white; font-size: 14px; font-weight: bold;">
                <%= user.name.charAt(0).toUpperCase() %>
              </div>
              <span class="d-none d-md-inline"><%= user.name %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2">
              <li><a class="dropdown-item py-2 px-3" href="/user/dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
              <% if (user.role === 'admin') { %>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item py-2 px-3" href="/admin/dashboard"><i class="fas fa-cog me-2"></i>Admin Panel</a></li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item py-2 px-3 text-danger" href="/user/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link px-3 py-2 mx-1 rounded-pill btn btn-primary text-white fw-medium" href="/user/login">
              <i class="fas fa-sign-in-alt me-1"></i>Login
            </a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<!-- Custom CSS for dashboard navbar -->
<style>
.navbar-nav .nav-link {
  transition: all 0.3s ease;
}

.navbar-nav .nav-link:hover {
  background-color: rgba(102, 126, 234, 0.1);
  color: #667eea !important;
}

.dropdown-menu {
  border-radius: 8px !important;
  padding: 8px 0 !important;
  border: none !important;
  box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
}

.dropdown-item {
  transition: all 0.2s ease !important;
  margin: 2px 8px !important;
  border-radius: 6px !important;
  padding: 8px 12px !important;
}

.dropdown-item:hover {
  background-color: rgba(102, 126, 234, 0.1) !important;
  color: #667eea !important;
  transform: translateX(4px) !important;
}

.navbar-toggler:focus {
  box-shadow: none;
}

@media (max-width: 991.98px) {
  .navbar-collapse {
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    margin-top: 16px;
    padding: 16px;
  }
}
</style>
