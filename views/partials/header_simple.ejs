<!-- Navigation Styles and Scripts -->
<style>
/* Reset all BS defaults for underlines */
a.nav-link {
  text-decoration: none !important;
  border-bottom: none !important;
  outline: none !important;
}

a.nav-link:hover,
a.nav-link:active,
a.nav-link:focus {
  text-decoration: none !important;
  border-bottom: none !important;
  outline: none !important;
}

/* Premium Navbar Styling */
.premium-navbar {
  padding: 12px 0;
}

.logo-section {
  transition: all 0.3s ease;
}

.logo-section:hover img {
  transform: scale(1.08);
}

/* Enhanced Navigation Items */
.nav-item-enhanced {
  position: relative;
  padding: 8px 16px !important;
  margin: 0 4px;
  border-radius: 8px;
  transition: all 0.3s ease;
  font-weight: 600;
  color: #2c3e50 !important;
  text-decoration: none !important;
  display: inline-flex !important;
  align-items: center;
  background: transparent;
  border: 2px solid transparent;
}

.nav-item-enhanced::before {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 0;
  height: 3px;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 2px;
  transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.nav-item-enhanced:hover::before {
  width: 100%;
}

.nav-item-enhanced .nav-icon {
  font-size: 18px;
  margin-right: 8px !important;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  color: #667eea;
}

.nav-item-enhanced:hover {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.08) 100%) !important;
  color: #667eea !important;
  transform: translateY(-2px);
  text-decoration: none !important;
  border: 2px solid rgba(102, 126, 234, 0.2) !important;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
}

.nav-item-enhanced:hover .nav-icon {
  transform: scale(1.2) rotate(8deg);
  color: #667eea;
}

.nav-item-enhanced.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.12) 100%) !important;
  color: #667eea !important;
  border: 2px solid #667eea !important;
  box-shadow: 0 4px 16px rgba(102, 126, 234, 0.25);
}

.nav-item-enhanced.active::before {
  width: 100%;
}

/* Submenu Styling */
.nav-submenu {
  position: relative;
}

.submenu-arrow {
  transition: transform 0.3s ease;
}

.nav-submenu:hover .submenu-arrow {
  transform: rotate(180deg);
  color: #667eea !important;
}

.premium-submenu {
  background: white;
  border: 2px solid #667eea;
  border-radius: 10px;
  box-shadow: 0 8px 24px rgba(102, 126, 234, 0.2);
  padding: 10px 0;
  min-width: 240px;
  list-style: none;
  margin: 0;
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  z-index: 1000;
}

.nav-submenu:hover .premium-submenu {
  display: block;
}

.premium-submenu-item {
  display: flex !important;
  align-items: center !important;
  padding: 12px 16px !important;
  color: #2c3e50 !important;
  text-decoration: none !important;
  border-radius: 6px;
  margin: 4px 8px;
  transition: all 0.3s ease !important;
  font-size: 14px;
  font-weight: 500;
}

.premium-submenu-item:hover {
  background: rgba(102, 126, 234, 0.1) !important;
  color: #667eea !important;
  padding-left: 20px !important;
}

/* Action Buttons */
.action-btn {
  transition: all 0.3s ease !important;
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
  border: none !important;
}

.action-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
}

/* Mobile Toggle */
.navbar-mobile-toggle {
  display: none;
  background: none;
  border: none;
  font-size: 24px;
  color: #333;
  cursor: pointer;
  padding: 8px 12px;
  transition: all 0.3s ease;
}

.navbar-mobile-toggle:hover {
  color: #667eea;
  transform: scale(1.1);
}

/* Desktop: Show navbar */
@media (min-width: 992px) {
  .navbar-collapse {
    display: flex !important;
  }

  .navbar-mobile-toggle {
    display: none !important;
  }

  .mobile-navbar-sidebar,
  .mobile-navbar-overlay {
    display: none !important;
  }
}

/* Mobile: Hide navbar */
@media (max-width: 991.98px) {
  .navbar-collapse {
    display: none !important;
  }

  .navbar-mobile-toggle {
    display: block !important;
  }
}
</style>

<script>
function openMobileNav() {
  document.getElementById('mobileNavbarSidebar').style.left = '0';
  document.getElementById('mobileNavbarOverlay').style.display = 'block';
  document.body.style.overflow = 'hidden';
}

function closeMobileNav() {
  document.getElementById('mobileNavbarSidebar').style.left = '-100%';
  document.getElementById('mobileNavbarOverlay').style.display = 'none';
  document.body.style.overflow = 'auto';
}

// Close sidebar when overlay is clicked
document.addEventListener('DOMContentLoaded', function() {
  const overlay = document.getElementById('mobileNavbarOverlay');
  if (overlay) {
    overlay.addEventListener('click', closeMobileNav);
  }
});
</script>
