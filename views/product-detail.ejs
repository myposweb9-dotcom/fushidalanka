<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - FushidaLanka</title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="description" content="<%= product.description || 'High-quality hardware and tools from FushidaLanka' %>">
  <meta name="keywords" content="solar energy, solar panels, renewable energy, <%= product.name %>">
</head>
<body>
<%- include('./partials/header') %>

<!-- Hero Section -->
<section class="hero-section">
  <video autoplay loop muted playsinline class="hero-background-video">
    <source src="/images/vdo1234.mp4" type="video/mp4">
    Your browser does not support the video tag.
  </video>
  <div class="hero-overlay"></div>
  <div class="container position-relative">
    <div class="row align-items-center justify-content-center">
      <div class="col-lg-6 text-center text-lg-start">
        <h1 class="display-4 fw-bold mb-4 text-white"><%= product.name %></h1>
        <p class="lead mb-4 text-white-75"><%= product.description || 'High-quality solar equipment for your energy needs.' %></p>
        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
          <a href="/contact" class="btn btn-light btn-lg">Get Quote</a>
          <% if (product.datasheet) { %>
            <a href="<%= product.datasheet %>" class="btn btn-outline-light btn-lg" download>
              <i class="fas fa-download me-2"></i>Download Datasheet
            </a>
          <% } %>
        </div>
      </div>
       <div class="col-lg-6">
        <% if (product.images && product.images.length > 0) { %>
          <img src="<%= product.images[0] %>" alt="<%= product.name %>" class="img-fluid rounded shadow">
        <% } else { %>
          <img src="https://via.placeholder.com/600x400/28a745/ffffff?text=<%= encodeURIComponent(product.name) %>" alt="<%= product.name %>" class="img-fluid rounded shadow">
        <% } %>
      </div>
    </div>
  </div>
</section>

<!-- Product Details Section -->
<section class="py-5">
  <div class="container">
    <div class="row">
      <div class="col-lg-8">
        <div class="card shadow">
          <div class="card-body">
            <h2 class="card-title mb-4">Product Details</h2>

            <!-- Product Images Gallery -->
            <% if (product.images && product.images.length > 1) { %>
              <div class="mb-4">
                <h5>Product Images</h5>
                <div class="row">
                  <% product.images.forEach((image, index) => { %>
                    <div class="col-md-4 mb-3">
                      <img src="<%= image %>" alt="<%= product.name %> - Image <%= index + 1 %>" class="img-fluid rounded">
                    </div>
                  <% }); %>
                </div>
              </div>
            <% } %>

            <!-- Description -->
            <div class="mb-4">
              <h5>Description</h5>
              <p class="text-muted"><%= product.description || 'Detailed product information coming soon.' %></p>
            </div>

            <!-- Specifications -->
            <% if (product.specifications) { %>
              <div class="mb-4">
                <h5>Specifications</h5>
                <div class="table-responsive">
                  <table class="table table-striped">
                    <tbody>
                      <% Object.entries(product.specifications).forEach(([key, value]) => { %>
                        <tr>
                          <td class="fw-bold"><%= key %></td>
                          <td><%= value %></td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% } %>

            <!-- Category -->
            <% if (product.category) { %>
              <div class="mb-4">
                <h5>Category</h5>
                <span class="badge bg-primary"><%= product.category.name %></span>
              </div>
            <% } %>

            <!-- Stock Status -->
            <div class="mb-4">
              <h5>Availability</h5>
              <span class="badge <%= product.stock > 0 ? 'bg-success' : 'bg-warning' %>">
                <%= product.stock > 0 ? `In Stock (${product.stock} available)` : 'Out of Stock' %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <!-- Pricing Card -->
        <div class="card shadow mb-4">
          <div class="card-body">
            <h5 class="card-title">Pricing</h5>
            <div class="display-6 text-primary fw-bold mb-3">
              LKR <%= product.price || 'Contact for pricing' %>
            </div>
            <a href="/contact" class="btn btn-success btn-lg w-100 mb-2">Request Quote</a>
            <%
              const whatsappMessage = encodeURIComponent(`Hi, I'm interested in the ${product.name}. Can you provide more details about this product?

Product: ${product.name}
Price: LKR ${product.price || 'Contact for pricing'}
${product.description ? `Description: ${product.description}` : ''}

Please share more information.`);
              const whatsappUrl = `https://wa.me/94774116702?text=${whatsappMessage}`;
            %>
            <a href="<%= whatsappUrl %>" target="_blank" class="btn btn-success btn-lg w-100" style="background-color: #25D366; border-color: #25D366;">
              <i class="fab fa-whatsapp me-2"></i>Chat on WhatsApp
            </a>
          </div>
        </div>

        <!-- Quick Info Card -->
        <div class="card shadow">
          <div class="card-body">
            <h5 class="card-title">Quick Info</h5>
            <ul class="list-unstyled">
              <li class="mb-2">
                <i class="fas fa-tag text-primary me-2"></i>
                <strong>Category:</strong> <%= product.category ? product.category.name : 'N/A' %>
              </li>
              <li class="mb-2">
                <i class="fas fa-boxes text-primary me-2"></i>
                <strong>Stock:</strong> <%= product.stock || 0 %> units
              </li>
              <li class="mb-2">
                <i class="fas fa-info-circle text-primary me-2"></i>
                <strong>Status:</strong>
                <span class="badge <%= product.status === 'active' ? 'bg-success' : 'bg-secondary' %>">
                  <%= product.status || 'active' %>
                </span>
              </li>
              <% if (product.datasheet) { %>
                <li class="mb-2">
                  <i class="fas fa-file-pdf text-primary me-2"></i>
                  <strong>Datasheet:</strong> Available
                </li>
              <% } %>
            </ul>
          </div>
        </div>

        <!-- Related Products -->
        <div class="card shadow mt-4">
          <div class="card-body">
            <h5 class="card-title">Need More Information?</h5>
            <p class="text-muted mb-3">Contact our experts for detailed specifications and custom solutions.</p>
            <a href="/contact" class="btn btn-outline-primary w-100">Contact Us</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Related Products Section -->
<section class="py-5 bg-light">
  <div class="container">
    <h2 class="text-center mb-5">Explore More Products</h2>
    <div class="row">
      <!-- This could be populated with related products in the future -->
      <div class="col-12 text-center">
        <a href="/#products-section" class="btn btn-primary btn-lg">View All Products</a>
      </div>
    </div>
  </div>
</section>

<%- include('./partials/footer') %>

<!-- Floating WhatsApp Button -->
<a href="<%= whatsappUrl %>" target="_blank" class="whatsapp-float" title="Chat on WhatsApp">
  <i class="fab fa-whatsapp"></i>
</a>

<style>
.whatsapp-float {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 60px;
  height: 60px;
  background-color: #25D366;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  box-shadow: 0 4px 12px rgba(37, 211, 102, 0.4);
  transition: all 0.3s ease;
  z-index: 1000;
  text-decoration: none;
}

.whatsapp-float:hover {
  transform: scale(1.1);
  box-shadow: 0 6px 16px rgba(37, 211, 102, 0.6);
}

.whatsapp-float:active {
  transform: scale(0.95);
}

@media (max-width: 768px) {
  .whatsapp-float {
    width: 50px;
    height: 50px;
    font-size: 20px;
    bottom: 15px;
    right: 15px;
  }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
