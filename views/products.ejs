<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <meta name="description" content="FushidaLanka Hardware - Premium tools, building materials, electrical supplies, and safety equipment. Shop quality products online.">
  <meta name="keywords" content="hardware shop, tools, building materials, electrical, safety gear, home improvement">
</head>
<body>
<%- include('partials/header') %>

<!-- Hero Section with Video -->
<section class="hero-section">
  <video muted playsinline class="hero-background-video" id="heroVideo">
    <source src="/images/vdo1234.mp4" type="video/mp4">
    Your browser does not support the video tag.
  </video>
  <div class="hero-overlay" style="background-color: rgba(0, 0, 0, 0.2);"></div>
  <div class="container position-relative">
    <div class="row align-items-center justify-content-center">
      <div class="col-lg-8 text-center">
        <h1 class="display-3 fw-bold text-white mb-3">Our Products</h1>
        <p class="lead text-white-75">Explore our complete collection of premium tools, building materials, and hardware solutions.</p>
        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-4">
          <a href="#products-section" class="btn btn-hero btn-lg">Browse Products</a>
          <a href="/contact" class="btn btn-outline-light btn-lg">Get Help</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Category Filter Section -->
<section style="background: white; padding: 50px 0; border-bottom: 1px solid rgba(31, 61, 36, 0.1);">
  <div class="container">
    <div class="text-center mb-4">
      <h3 class="fw-bold mb-3" style="font-size: 1.8rem; color: #2c3e50;">Filter by Category</h3>
      <p class="text-muted">Select a category to view products</p>
    </div>

    <!-- Category Buttons -->
    <div class="d-flex flex-wrap justify-content-center gap-3 mb-3">
      <button class="btn category-filter-btn active" data-category="all" onclick="filterProducts('all', event)" style="padding: 10px 25px; font-weight: 600; border: 2px solid #1F3D24; color: white; background: #1F3D24; transition: all 0.3s ease; cursor: pointer; border-radius: 25px;">
        <i class="fas fa-th-large me-2"></i>All Products
      </button>
      <% if (categories && categories.length > 0) { %>
        <% categories.forEach(category => { %>
          <button class="btn category-filter-btn" data-category="<%= category.id %>" onclick="filterProducts('<%= category.id %>', event)" style="padding: 10px 25px; font-weight: 600; border: 2px solid #1F3D24; color: #1F3D24; background: white; transition: all 0.3s ease; cursor: pointer; border-radius: 25px;">
            <i class="fas fa-tag me-2"></i><%= category.name %>
          </button>
        <% }); %>
      <% } %>
    </div>
  </div>
</section>

<!-- Products Section -->
<section id="products-section" class="py-5" style="background: white;">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="section-title" style="font-size: 2.5rem;">All Products</h2>
      <p class="text-muted" style="font-size: 1.1rem;">Browse our wide selection of quality products from FushidaLanka</p>
    </div>
    
    <div class="row" id="products-grid">
      <% if (products && products.length > 0) { %>
        <% products.forEach((product, index) => { %>
          <div class="col-lg-4 col-md-6 mb-4 product-item" data-category="<%= product.categoryId || 'all' %>">
            <div class="card h-100 shadow-sm border-light product-card" style="border: 1px solid rgba(31, 61, 36, 0.1); transition: all 0.3s ease; cursor: pointer; overflow: hidden;">
              <div class="position-relative overflow-hidden" style="height: 220px; background: linear-gradient(135deg, #e8f1eb 0%, #d4e8dc 100%);">
                <% if (product.images && product.images.length > 0) { %>
                  <img src="<%= product.images[0] %>" class="card-img-top" alt="<%= product.name %>" style="height: 100%; width: 100%; object-fit: cover; transition: transform 0.4s ease;">
                <% } else { %>
                  <div style="height: 100%; width: 100%; display: flex; align-items: center; justify-content: center; font-size: 3rem; color: rgba(31, 61, 36, 0.3);"><i class="fas fa-cube"></i></div>
                <% } %>
                <div class="position-absolute top-0 end-0 m-3">
                  <span class="badge" style="background: linear-gradient(135deg, #1F3D24, #ffffff); padding: 8px 12px; color: white; font-weight: 600;">NEW</span>
                </div>
              </div>
              <div class="card-body d-flex flex-column" style="padding: 1.5rem;">
                <h5 class="card-title fw-bold mb-2" style="color: #2c3e50; font-size: 1.1rem;"><%= product.name %></h5>
                <% if (product.category) { %>
                  <span class="badge mb-2" style="width: fit-content; background: rgba(31, 61, 36, 0.1); color: #1F3D24; font-weight: 600; font-size: 0.85rem;">
                    <i class="fas fa-tag me-1"></i><%= product.category.name %>
                  </span>
                <% } %>
                <p class="card-text text-muted small" style="line-height: 1.5; flex-grow: 1;"><%= product.description ? product.description.substring(0, 80) + '...' : 'Premium quality product' %></p>
                <div class="d-flex justify-content-between align-items-center mt-auto pt-3">
                  <span style="font-size: 1.2rem; font-weight: 700; color: #1F3D24;">LKR <%= product.price ? parseInt(product.price).toLocaleString('en-US') : 'Contact' %></span>
                </div>
                <a href="/products/<%= product.id %>" class="product-view-btn" style="width: 100%;">
                  <i class="fas fa-eye me-2"></i>View Details
                </a>
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="col-12 text-center py-5">
          <i class="fas fa-box-open fa-5x text-muted mb-4" style="opacity: 0.5;"></i>
          <h3 class="text-muted mb-2">No Products Found</h3>
          <p class="text-muted">Please check back soon for more products!</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- Logos Bar Section -->
<% if (logos && logos.length > 0) { %>
<section style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); border-top: 1px solid #dee2e6; border-bottom: 1px solid #dee2e6; padding: 2rem 0; overflow: hidden;">
  <div class="container-fluid">
    <div style="display: flex; animation: scrollLogos 30s linear infinite;">
      <% logos.forEach(logo => { %>
      <div style="flex-shrink: 0; padding: 0 20px; display: flex; align-items: center; justify-content: center; min-width: 200px;">
        <img src="<%= logo.image %>" alt="<%= logo.title || 'Partner Logo' %>" style="height: 60px; width: auto; max-width: 150px; object-fit: contain; filter: grayscale(100%) brightness(0.7); transition: all 0.3s ease;">
      </div>
      <% }); %>
      <% logos.forEach(logo => { %>
      <div style="flex-shrink: 0; padding: 0 20px; display: flex; align-items: center; justify-content: center; min-width: 200px;">
        <img src="<%= logo.image %>" alt="<%= logo.title || 'Partner Logo' %>" style="height: 60px; width: auto; max-width: 150px; object-fit: contain; filter: grayscale(100%) brightness(0.7); transition: all 0.3s ease;">
      </div>
      <% }); %>
    </div>
  </div>
  <style>
    @keyframes scrollLogos {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>
</section>
<% } %>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Product Filtering and Smooth Scrolling
  function filterProducts(categoryId, event) {
    event.preventDefault();

    // Update active button state
    document.querySelectorAll('.category-filter-btn').forEach(btn => {
      btn.style.background = 'white';
      btn.style.color = '#1F3D24';
      btn.classList.remove('active');
    });
    
    event.target.closest('button').style.background = '#1F3D24';
    event.target.closest('button').style.color = 'white';
    event.target.closest('button').classList.add('active');

    // Filter products
    const productItems = document.querySelectorAll('.product-item');
    let visibleCount = 0;

    productItems.forEach((item, index) => {
      const itemCategory = item.getAttribute('data-category');
      if (categoryId === 'all' || itemCategory === categoryId) {
        item.style.display = 'block';
        item.classList.add('animate-on-scroll', 'animate-slide-in-up-smooth', `animate-delay-${(index % 4) + 1}`);
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    // Smooth scroll to products section
    setTimeout(() => {
      const productsSection = document.getElementById('products-section');
      if (productsSection) {
        productsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }, 100);
  }

  // Add hover effect to product cards
  document.querySelectorAll('.product-card').forEach(card => {
    card.addEventListener('mouseenter', function() {
      this.style.transform = 'translateY(-8px)';
      this.style.boxShadow = '0 15px 40px rgba(31, 61, 36, 0.2)';
    });
    
    card.addEventListener('mouseleave', function() {
      this.style.transform = 'translateY(0)';
      this.style.boxShadow = '';
    });
  });

  // Auto-play hero video
  document.addEventListener('DOMContentLoaded', function() {
    const heroVideo = document.getElementById('heroVideo');
    if (heroVideo) {
      heroVideo.autoplay = true;
      heroVideo.play().catch(err => {
        console.log('Video autoplay prevented:', err);
        document.addEventListener('click', () => {
          heroVideo.play().catch(e => console.log('Play failed:', e));
        }, { once: true });
      });
    }
  });
</script>
<script src="/js/main.js"></script>
</body>
</html>
