<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .analytics-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 2rem 0;
      margin-bottom: 2rem;
      border-radius: 0 0 20px 20px;
    }
    .analytics-card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 1.5rem;
    }
    .metric-card {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border-radius: 15px;
      padding: 2rem;
      margin-bottom: 1.5rem;
      transition: transform 0.3s ease;
    }
    .metric-card:hover {
      transform: translateY(-5px);
    }
    .metric-card h3 {
      font-size: 2.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .metric-card p {
      margin: 0;
      opacity: 0.9;
      font-size: 1.1rem;
    }
    .chart-container {
      position: relative;
      height: 300px;
      margin-bottom: 2rem;
    }
    .sidebar-card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 1.5rem;
    }
    .sidebar-profile {
      text-align: center;
      padding: 1.5rem;
    }
    .sidebar-profile img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      margin-bottom: 1rem;
      border: 4px solid #667eea;
    }
    .sidebar-nav .nav-link {
      color: #495057;
      padding: 0.75rem 1rem;
      margin-bottom: 0.25rem;
      border-radius: 8px;
      transition: all 0.3s ease;
      font-weight: 500;
    }
    .sidebar-nav .nav-link:hover,
    .sidebar-nav .nav-link.active {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      transform: translateX(5px);
    }
    .sidebar-nav .nav-link i {
      margin-right: 0.5rem;
      width: 20px;
    }
    .performance-indicator {
      display: inline-flex;
      align-items: center;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.875rem;
      font-weight: 600;
    }
    .performance-up {
      background-color: #d4edda;
      color: #155724;
    }
    .performance-down {
      background-color: #f8d7da;
      color: #721c24;
    }
    .performance-neutral {
      background-color: #e8f1eb;
      color: #1F3D24;
    }
  </style>
</head>
<body>
  <%- include('../partials/dashboard-header') %>

  <div class="analytics-header">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h1 class="mb-2"><i class="fas fa-chart-bar me-3"></i>Analytics</h1>
          <p class="mb-0 fs-5">Track your performance and sales insights.</p>
        </div>
        <div class="col-md-4 text-end">
          <a href="/user/dashboard" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- Main Content -->
    <div class="col-12">
        <!-- Key Metrics -->
        <div class="row mb-4">
          <div class="col-md-3">
            <div class="metric-card">
              <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                  <h3>1,247</h3>
                  <p>Total Views</p>
                </div>
                <div class="ms-3">
                  <i class="fas fa-eye fa-2x opacity-75"></i>
                </div>
              </div>
              <div class="mt-2">
                <span class="performance-indicator performance-up">
                  <i class="fas fa-arrow-up me-1"></i>+12.5%
                </span>
                <small class="ms-2 opacity-75">vs last month</small>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="metric-card">
              <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                  <h3>89</h3>
                  <p>Inquiries</p>
                </div>
                <div class="ms-3">
                  <i class="fas fa-envelope fa-2x opacity-75"></i>
                </div>
              </div>
              <div class="mt-2">
                <span class="performance-indicator performance-up">
                  <i class="fas fa-arrow-up me-1"></i>+8.2%
                </span>
                <small class="ms-2 opacity-75">vs last month</small>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="metric-card">
              <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                  <h3>23</h3>
                  <p>Sales</p>
                </div>
                <div class="ms-3">
                  <i class="fas fa-shopping-cart fa-2x opacity-75"></i>
                </div>
              </div>
              <div class="mt-2">
                <span class="performance-indicator performance-down">
                  <i class="fas fa-arrow-down me-1"></i>-3.1%
                </span>
                <small class="ms-2 opacity-75">vs last month</small>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="metric-card">
              <div class="d-flex align-items-center">
                <div class="flex-grow-1">
                  <h3>$12,450</h3>
                  <p>Revenue</p>
                </div>
                <div class="ms-3">
                  <i class="fas fa-dollar-sign fa-2x opacity-75"></i>
                </div>
              </div>
              <div class="mt-2">
                <span class="performance-indicator performance-up">
                  <i class="fas fa-arrow-up me-1"></i>+15.7%
                </span>
                <small class="ms-2 opacity-75">vs last month</small>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <!-- Sales Chart -->
          <div class="col-md-8">
            <div class="analytics-card">
              <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-chart-line text-primary me-2"></i>Sales Trend</h5>
              </div>
              <div class="card-body">
                <div class="chart-container">
                  <canvas id="salesChart"></canvas>
                </div>
              </div>
            </div>
          </div>

          <!-- Top Products -->
          <div class="col-md-4">
            <div class="analytics-card">
              <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-trophy text-warning me-2"></i>Top Products</h5>
              </div>
              <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                  <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                    <span class="text-white fw-bold">1</span>
                  </div>
                  <div class="flex-grow-1">
                    <h6 class="mb-1">Monocrystalline Solar Panel 400W</h6>
                    <small class="text-muted">23 sales • $6,899.77</small>
                  </div>
                </div>
                <div class="d-flex align-items-center mb-3">
                  <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                    <span class="text-white fw-bold">2</span>
                  </div>
                  <div class="flex-grow-1">
                    <h6 class="mb-1">Hybrid Solar Inverter 5KW</h6>
                    <small class="text-muted">18 sales • $23,399.82</small>
                  </div>
                </div>
                <div class="d-flex align-items-center mb-3">
                  <div class="bg-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                    <span class="text-white fw-bold">3</span>
                  </div>
                  <div class="flex-grow-1">
                    <h6 class="mb-1">Lithium Battery 10KWh</h6>
                    <small class="text-muted">12 sales • $29,999.88</small>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <!-- Traffic Sources -->
          <div class="col-md-6">
            <div class="analytics-card">
              <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-globe text-info me-2"></i>Traffic Sources</h5>
              </div>
              <div class="card-body">
                <div class="chart-container">
                  <canvas id="trafficChart"></canvas>
                </div>
              </div>
            </div>
          </div>

          <!-- Recent Activity -->
          <div class="col-md-6">
            <div class="analytics-card">
              <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <h5 class="mb-0"><i class="fas fa-clock text-success me-2"></i>Recent Activity</h5>
              </div>
              <div class="card-body p-0">
                <div class="list-group list-group-flush">
                  <div class="list-group-item px-4 py-3">
                    <div class="d-flex">
                      <div class="activity-icon bg-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="fas fa-shopping-cart text-white"></i>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="mb-1">New Sale</h6>
                        <p class="text-muted mb-1">Sold 2x Monocrystalline Solar Panel 400W</p>
                        <small class="text-muted">2 hours ago</small>
                      </div>
                    </div>
                  </div>
                  <div class="list-group-item px-4 py-3">
                    <div class="d-flex">
                      <div class="activity-icon bg-info rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="fas fa-envelope text-white"></i>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="mb-1">New Inquiry</h6>
                        <p class="text-muted mb-1">Customer interested in Hybrid Solar Inverter</p>
                        <small class="text-muted">4 hours ago</small>
                      </div>
                    </div>
                  </div>
                  <div class="list-group-item px-4 py-3">
                    <div class="d-flex">
                      <div class="activity-icon bg-warning rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="fas fa-eye text-white"></i>
                      </div>
                      <div class="flex-grow-1">
                        <h6 class="mb-1">Product View</h6>
                        <p class="text-muted mb-1">Lithium Battery 10KWh viewed 15 times</p>
                        <small class="text-muted">6 hours ago</small>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/js/main.js"></script>
  <script>
    // Sales Chart
    const salesCtx = document.getElementById('salesChart').getContext('2d');
    new Chart(salesCtx, {
      type: 'line',
      data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
        datasets: [{
          label: 'Sales ($)',
          data: [8500, 9200, 7800, 10500, 11200, 12800, 12450],
          borderColor: '#667eea',
          backgroundColor: 'rgba(102, 126, 234, 0.1)',
          tension: 0.4,
          fill: true
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: function(value) {
                return '$' + value.toLocaleString();
              }
            }
          }
        }
      }
    });

    // Traffic Sources Chart
    const trafficCtx = document.getElementById('trafficChart').getContext('2d');
    new Chart(trafficCtx, {
      type: 'doughnut',
      data: {
        labels: ['Direct', 'Search Engines', 'Social Media', 'Referrals'],
        datasets: [{
          data: [45, 30, 15, 10],
          backgroundColor: [
            '#667eea',
            '#764ba2',
            '#f093fb',
            '#f5576c'
          ],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom'
          }
        }
      }
    });
  </script>
</body>
</html>
