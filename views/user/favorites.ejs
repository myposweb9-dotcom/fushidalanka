<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .favorites-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 2rem 0;
      margin-bottom: 2rem;
      border-radius: 0 0 20px 20px;
    }
    .product-card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 1.5rem;
      transition: transform 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .product-card:hover {
      transform: translateY(-5px);
    }
    .product-image {
      height: 200px;
      object-fit: cover;
      border-radius: 15px 15px 0 0;
    }
    .product-body {
      padding: 1.5rem;
    }
    .product-title {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: #333;
    }
    .product-price {
      font-size: 1.25rem;
      font-weight: 700;
      color: #667eea;
      margin-bottom: 0.5rem;
    }
    .product-description {
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    .rating {
      color: #ffc107;
      margin-bottom: 1rem;
    }
    .favorite-btn {
      position: absolute;
      top: 15px;
      right: 15px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
      border: none;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      z-index: 10;
      box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
    }
    .favorite-btn:hover {
      transform: scale(1.1);
      box-shadow: 0 6px 20px rgba(255, 107, 107, 0.4);
    }
    .favorite-btn.active {
      background: linear-gradient(135deg, #ff4757 0%, #ff3838 100%);
    }
    .sidebar-card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 1.5rem;
    }
    .sidebar-profile {
      text-align: center;
      padding: 1.5rem;
    }
    .sidebar-profile img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      margin-bottom: 1rem;
      border: 4px solid #667eea;
    }
    .sidebar-nav .nav-link {
      color: #495057;
      padding: 0.75rem 1rem;
      margin-bottom: 0.25rem;
      border-radius: 8px;
      transition: all 0.3s ease;
      font-weight: 500;
    }
    .sidebar-nav .nav-link:hover,
    .sidebar-nav .nav-link.active {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      transform: translateX(5px);
    }
    .sidebar-nav .nav-link i {
      margin-right: 0.5rem;
      width: 20px;
    }
    .empty-state {
      text-align: center;
      padding: 3rem 2rem;
    }
    .empty-state i {
      font-size: 4rem;
      color: #ddd;
      margin-bottom: 1rem;
    }
    .empty-state h4 {
      color: #666;
      margin-bottom: 1rem;
    }
    .empty-state p {
      color: #999;
      margin-bottom: 2rem;
    }
  </style>
</head>
<body>
  <%- include('../partials/dashboard-header') %>

  <div class="favorites-header">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h1 class="mb-2"><i class="fas fa-heart me-3"></i>My Favorites</h1>
          <p class="mb-0 fs-5">Products you've saved for later.</p>
        </div>
        <div class="col-md-4 text-end">
          <a href="/user/dashboard" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- Main Content -->
    <div class="col-12">
        <div class="row" id="favoritesContainer">
          <!-- Sample Favorite Product 1 -->
          <div class="col-md-6 col-lg-4">
            <div class="product-card">
              <button class="favorite-btn active" onclick="toggleFavorite(this)">
                <i class="fas fa-heart"></i>
              </button>
              <img src="https://via.placeholder.com/300x200/667eea/ffffff?text=Solar+Panel" alt="Monocrystalline Solar Panel 400W" class="product-image">
              <div class="product-body">
                <h5 class="product-title">Monocrystalline Solar Panel 400W</h5>
                <div class="product-price">$399.99</div>
                <div class="rating">
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star-half-alt"></i>
                  <span class="ms-1">(4.5)</span>
                </div>
                <p class="product-description">High-efficiency monocrystalline solar panel with advanced cell technology for maximum power output.</p>
                <div class="d-flex gap-2">
                  <a href="/product-detail?id=1" class="btn btn-outline-primary btn-sm flex-fill">
                    <i class="fas fa-eye me-1"></i>View
                  </a>
                  <button class="btn btn-primary btn-sm flex-fill" onclick="addToCart(1)">
                    <i class="fas fa-cart-plus me-1"></i>Add to Cart
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Sample Favorite Product 2 -->
          <div class="col-md-6 col-lg-4">
            <div class="product-card">
              <button class="favorite-btn active" onclick="toggleFavorite(this)">
                <i class="fas fa-heart"></i>
              </button>
              <img src="https://via.placeholder.com/300x200/667eea/ffffff?text=Inverter" alt="Hybrid Solar Inverter 5KW" class="product-image">
              <div class="product-body">
                <h5 class="product-title">Hybrid Solar Inverter 5KW</h5>
                <div class="product-price">$1,299.99</div>
                <div class="rating">
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <span class="ms-1">(5.0)</span>
                </div>
                <p class="product-description">Advanced hybrid inverter with MPPT technology for optimal solar energy conversion.</p>
                <div class="d-flex gap-2">
                  <a href="/product-detail?id=2" class="btn btn-outline-primary btn-sm flex-fill">
                    <i class="fas fa-eye me-1"></i>View
                  </a>
                  <button class="btn btn-primary btn-sm flex-fill" onclick="addToCart(2)">
                    <i class="fas fa-cart-plus me-1"></i>Add to Cart
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Sample Favorite Product 3 -->
          <div class="col-md-6 col-lg-4">
            <div class="product-card">
              <button class="favorite-btn active" onclick="toggleFavorite(this)">
                <i class="fas fa-heart"></i>
              </button>
              <img src="https://via.placeholder.com/300x200/667eea/ffffff?text=Battery" alt="Lithium Battery 10KWh" class="product-image">
              <div class="product-body">
                <h5 class="product-title">Lithium Battery 10KWh</h5>
                <div class="product-price">$2,499.99</div>
                <div class="rating">
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star"></i>
                  <i class="fas fa-star-half-alt"></i>
                  <span class="ms-1">(4.7)</span>
                </div>
                <p class="product-description">High-capacity lithium-ion battery for reliable energy storage and backup power.</p>
                <div class="d-flex gap-2">
                  <a href="/product-detail?id=3" class="btn btn-outline-primary btn-sm flex-fill">
                    <i class="fas fa-eye me-1"></i>View
                  </a>
                  <button class="btn btn-primary btn-sm flex-fill" onclick="addToCart(3)">
                    <i class="fas fa-cart-plus me-1"></i>Add to Cart
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Empty State -->
        <div class="empty-state d-none" id="emptyFavorites">
          <i class="fas fa-heart-broken"></i>
          <h4>No Favorites Yet</h4>
          <p>You haven't added any products to your favorites yet. Start browsing our products and save the ones you like!</p>
          <a href="/products" class="btn btn-primary">
            <i class="fas fa-search me-2"></i>Browse Products
          </a>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
  <script>
    function toggleFavorite(button) {
      button.classList.toggle('active');
      const icon = button.querySelector('i');
      if (button.classList.contains('active')) {
        icon.className = 'fas fa-heart';
      } else {
        icon.className = 'far fa-heart';
      }
      // Here you would typically send an AJAX request to update favorites on the server
    }

    function addToCart(productId) {
      // Here you would typically send an AJAX request to add the product to cart
      alert('Product added to cart!');
    }

    // Check if there are any favorites and show/hide empty state accordingly
    document.addEventListener('DOMContentLoaded', function() {
      const favoritesContainer = document.getElementById('favoritesContainer');
      const emptyFavorites = document.getElementById('emptyFavorites');

      // This is just for demonstration - in a real app, you'd check if there are actual favorites
      const hasFavorites = favoritesContainer.children.length > 0;

      if (!hasFavorites) {
        emptyFavorites.classList.remove('d-none');
        favoritesContainer.classList.add('d-none');
      }
    });
  </script>
</body>
</html>
