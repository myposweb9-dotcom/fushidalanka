<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .orders-header {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 2rem 0;
      margin-bottom: 2rem;
      border-radius: 0 0 20px 20px;
    }
    .order-card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 1.5rem;
      transition: transform 0.3s ease;
    }
    .order-card:hover {
      transform: translateY(-2px);
    }
    .order-header {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      border-radius: 15px 15px 0 0;
      padding: 1rem;
    }
    .order-status {
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.875rem;
      font-weight: 600;
    }
    .status-pending { background-color: #e8f1eb; color: #1F3D24; }
    .status-processing { background-color: #cce5ff; color: #004085; }
    .status-shipped { background-color: #d1ecf1; color: #0c5460; }
    .status-delivered { background-color: #d4edda; color: #155724; }
    .status-cancelled { background-color: #f8d7da; color: #721c24; }
    .product-item {
      border-bottom: 1px solid #f8f9fa;
      padding: 1rem 0;
    }
    .product-item:last-child {
      border-bottom: none;
    }
    .sidebar-card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 1.5rem;
    }
    .sidebar-profile {
      text-align: center;
      padding: 1.5rem;
    }
    .sidebar-profile img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      margin-bottom: 1rem;
      border: 4px solid #667eea;
    }
    .sidebar-nav .nav-link {
      color: #495057;
      padding: 0.75rem 1rem;
      margin-bottom: 0.25rem;
      border-radius: 8px;
      transition: all 0.3s ease;
      font-weight: 500;
    }
    .sidebar-nav .nav-link:hover,
    .sidebar-nav .nav-link.active {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      transform: translateX(5px);
    }
    .sidebar-nav .nav-link i {
      margin-right: 0.5rem;
      width: 20px;
    }
  </style>
</head>
<body>
  <%- include('../partials/dashboard-header') %>

  <div class="orders-header">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-8">
          <h1 class="mb-2"><i class="fas fa-shopping-cart me-3"></i>My Orders</h1>
          <p class="mb-0 fs-5">Track your orders and purchase history.</p>
        </div>
        <div class="col-md-4 text-end">
          <a href="/user/dashboard" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <!-- Main Content -->
    <div class="col-12">
        <!-- Orders List -->
        <div id="ordersContainer">
          <!-- Sample Order 1 -->
          <div class="order-card">
            <div class="order-header">
              <div class="row align-items-center">
                <div class="col-md-6">
                  <h6 class="mb-1">Order #ORD-2024-001</h6>
                  <small class="text-muted">Placed on <%= new Date().toLocaleDateString() %></small>
                </div>
                <div class="col-md-6 text-end">
                  <span class="order-status status-delivered">Delivered</span>
                </div>
              </div>
            </div>
            <div class="card-body">
              <div class="product-item">
                <div class="row align-items-center">
                  <div class="col-md-2">
                    <img src="https://via.placeholder.com/80x80/667eea/ffffff?text=Product" alt="Product" class="img-fluid rounded">
                  </div>
                  <div class="col-md-6">
                    <h6 class="mb-1">Monocrystalline Solar Panel 400W</h6>
                    <p class="text-muted mb-0">Quantity: 2</p>
                  </div>
                  <div class="col-md-4 text-end">
                    <h6 class="mb-0">$799.98</h6>
                    <small class="text-muted">Delivered on <%= new Date(Date.now() - 86400000).toLocaleDateString() %></small>
                  </div>
                </div>
              </div>
              <div class="product-item">
                <div class="row align-items-center">
                  <div class="col-md-2">
                    <img src="https://via.placeholder.com/80x80/667eea/ffffff?text=Product" alt="Product" class="img-fluid rounded">
                  </div>
                  <div class="col-md-6">
                    <h6 class="mb-1">Hybrid Solar Inverter 5KW</h6>
                    <p class="text-muted mb-0">Quantity: 1</p>
                  </div>
                  <div class="col-md-4 text-end">
                    <h6 class="mb-0">$1,299.99</h6>
                    <small class="text-muted">Delivered on <%= new Date(Date.now() - 86400000).toLocaleDateString() %></small>
                  </div>
                </div>
              </div>
              <div class="row mt-3">
                <div class="col-md-6">
                  <p class="mb-0"><strong>Total: $2,099.97</strong></p>
                </div>
                <div class="col-md-6 text-end">
                  <button class="btn btn-outline-primary btn-sm me-2">
                    <i class="fas fa-eye me-1"></i>View Details
                  </button>
                  <button class="btn btn-outline-success btn-sm">
                    <i class="fas fa-redo me-1"></i>Reorder
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Sample Order 2 -->
          <div class="order-card">
            <div class="order-header">
              <div class="row align-items-center">
                <div class="col-md-6">
                  <h6 class="mb-1">Order #ORD-2024-002</h6>
                  <small class="text-muted">Placed on <%= new Date(Date.now() - 604800000).toLocaleDateString() %></small>
                </div>
                <div class="col-md-6 text-end">
                  <span class="order-status status-shipped">Shipped</span>
                </div>
              </div>
            </div>
            <div class="card-body">
              <div class="product-item">
                <div class="row align-items-center">
                  <div class="col-md-2">
                    <img src="https://via.placeholder.com/80x80/667eea/ffffff?text=Product" alt="Product" class="img-fluid rounded">
                  </div>
                  <div class="col-md-6">
                    <h6 class="mb-1">Lithium Battery 10KWh</h6>
                    <p class="text-muted mb-0">Quantity: 1</p>
                  </div>
                  <div class="col-md-4 text-end">
                    <h6 class="mb-0">$2,499.99</h6>
                    <small class="text-muted">Expected delivery: <%= new Date(Date.now() + 86400000).toLocaleDateString() %></small>
                  </div>
                </div>
              </div>
              <div class="row mt-3">
                <div class="col-md-6">
                  <p class="mb-0"><strong>Total: $2,499.99</strong></p>
                </div>
                <div class="col-md-6 text-end">
                  <button class="btn btn-outline-primary btn-sm me-2">
                    <i class="fas fa-eye me-1"></i>View Details
                  </button>
                  <button class="btn btn-outline-info btn-sm">
                    <i class="fas fa-truck me-1"></i>Track Order
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- No Orders Message -->
          <div class="text-center py-5" id="noOrdersMessage" style="display: none;">
            <i class="fas fa-shopping-cart fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">No Orders Yet</h4>
            <p class="text-muted">You haven't placed any orders yet. Start browsing our products!</p>
            <a href="/products" class="btn btn-primary">
              <i class="fas fa-search me-2"></i>Browse Products
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
